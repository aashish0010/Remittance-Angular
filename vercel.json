{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/remittance-angular/browser",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://remittance-api.fly.dev/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
