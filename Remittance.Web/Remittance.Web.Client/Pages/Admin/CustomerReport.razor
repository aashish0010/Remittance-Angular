@page "/admin/customer-report"
@using Remittance.Web.Client.Models
@using Remittance.Web.Client.Services
@inject ApiService Api
@inject AuthStateService Auth

<MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 700;">Customer Report</MudText>

@if (!string.IsNullOrEmpty(_message))
{
    <MudAlert Severity="@_severity" Class="mb-3" ShowCloseIcon="true" CloseIconClicked="() => _message = string.Empty">@_message</MudAlert>
}

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="3">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total Customers</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;">@_customers.Count</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Primary" />
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">KYC Verified</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;" Color="Color.Success">@_customers.Count(c => c.IsKycVerified)</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Large" Color="Color.Success" />
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Pending KYC</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;" Color="Color.Warning">@_customers.Count(c => !c.IsKycVerified)</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.HourglassBottom" Size="Size.Large" Color="Color.Warning" />
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">With Documents</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;" Color="Color.Info">@_customers.Count(c => c.Documents.Count > 0)</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Info" />
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudTable Items="_customers" Hover="true" Striped="true" Dense="true" Loading="_loading" Elevation="2">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Phone</MudTh>
        <MudTh>Country</MudTh>
        <MudTh>KYC Status</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.FullName</MudTd>
        <MudTd>@context.Phone</MudTd>
        <MudTd>@context.Country</MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Color="@(context.IsKycVerified ? Color.Success : Color.Warning)">
                @(context.IsKycVerified ? "Verified" : "Pending")
            </MudChip>
        </MudTd>
        <MudTd>
            <MudTooltip Text="View Details">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Info"
                               OnClick="@(() => ViewCustomer(context))" />
            </MudTooltip>
            @if (!context.IsKycVerified)
            {
                <MudTooltip Text="Approve KYC">
                    <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success"
                                   OnClick="@(() => ApproveKyc(context.Id))" />
                </MudTooltip>
            }
            else
            {
                <MudTooltip Text="Reject KYC">
                    <MudIconButton Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => RejectKyc(context.Id))" />
                </MudTooltip>
            }
        </MudTd>
    </RowTemplate>
</MudTable>

@* Customer Detail Popup *@
@if (_showDetail && _detailCustomer != null)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1300;" @onclick="@(() => _showDetail = false)"></div>
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1400; width: 600px; max-width: 95vw; max-height: 90vh; overflow-y: auto;">
        <MudPaper Elevation="8" Class="pa-6" Style="border-radius: 12px;">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Customer Details</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => _showDetail = false)" />
            </div>

            <MudGrid>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Full Name</MudText><MudText>@_detailCustomer.FullName</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Email</MudText><MudText>@(_detailCustomer.Email ?? "-")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Phone</MudText><MudText>@(_detailCustomer.Phone ?? "-")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Country</MudText><MudText>@_detailCustomer.Country</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Date of Birth</MudText><MudText>@(_detailCustomer.DateOfBirth?.ToString("yyyy-MM-dd") ?? "-")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Gender</MudText><MudText>@(_detailCustomer.Gender ?? "-")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Nationality</MudText><MudText>@(_detailCustomer.Nationality ?? "-")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">City</MudText><MudText>@(_detailCustomer.City ?? "-")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">State</MudText><MudText>@(_detailCustomer.State ?? "-")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Postal Code</MudText><MudText>@(_detailCustomer.PostalCode ?? "-")</MudText></MudItem>
                <MudItem xs="12"><MudText Typo="Typo.caption" Color="Color.Secondary">Address</MudText><MudText>@(_detailCustomer.Address ?? "-")</MudText></MudItem>
            </MudGrid>

            <MudDivider Class="my-3" />
            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;" Class="mb-2">ID Document</MudText>
            <MudGrid>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Type</MudText><MudText>@(_detailCustomer.IdDocumentType ?? "-")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Number</MudText><MudText>@(_detailCustomer.IdDocumentNumber ?? "-")</MudText></MudItem>
            </MudGrid>

            @if (_detailCustomer.Documents.Count > 0)
            {
                <MudDivider Class="my-3" />
                <MudText Typo="Typo.subtitle2" Style="font-weight: 600;" Class="mb-2">Documents (@_detailCustomer.Documents.Count)</MudText>
                @foreach (var doc in _detailCustomer.Documents)
                {
                    <MudChip T="string" Size="Size.Small" Color="@(doc.IsVerified ? Color.Success : Color.Warning)" Class="mr-1">
                        @doc.DocumentType — @doc.DocumentNumber
                    </MudChip>
                }
            }

            <MudDivider Class="my-3" />
            <MudGrid>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">KYC Status</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@(_detailCustomer.IsKycVerified ? Color.Success : Color.Warning)">
                        @(_detailCustomer.IsKycVerified ? "Verified" : "Pending")
                    </MudChip>
                </MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Created</MudText><MudText>@_detailCustomer.CreatedAt.ToString("yyyy-MM-dd HH:mm")</MudText></MudItem>
            </MudGrid>
        </MudPaper>
    </div>
}

@code {
    private List<CustomerModel> _customers = new();
    private bool _loading;
    private string _message = string.Empty;
    private Severity _severity = Severity.Info;
    private bool _showDetail;
    private CustomerModel? _detailCustomer;

    protected override async Task OnInitializedAsync()
    {
        await Auth.LoadFromSessionAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        var result = await Api.GetCustomersAsync();
        if (result?.Success == true)
            _customers = result.Data ?? new();
        _loading = false;
    }

    private void ViewCustomer(CustomerModel customer)
    {
        _detailCustomer = customer;
        _showDetail = true;
    }

    private async Task ApproveKyc(int id)
    {
        var result = await Api.ApproveKycAsync(id);
        _message = result?.Success == true ? "KYC approved." : (result?.Message ?? "Failed.");
        _severity = result?.Success == true ? Severity.Success : Severity.Error;
        await LoadData();
    }

    private async Task RejectKyc(int id)
    {
        var result = await Api.RejectKycAsync(id);
        _message = result?.Success == true ? "KYC rejected." : (result?.Message ?? "Failed.");
        _severity = result?.Success == true ? Severity.Success : Severity.Error;
        await LoadData();
    }
}
