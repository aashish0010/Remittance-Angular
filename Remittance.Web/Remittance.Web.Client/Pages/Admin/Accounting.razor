@page "/admin/setup"
@using Remittance.Web.Client.Models
@using Remittance.Web.Client.Services
@inject ApiService Api
@inject AuthStateService Auth

<MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 700;">Setup</MudText>

@if (!string.IsNullOrEmpty(_message))
{
    <MudAlert Severity="@_severity" Class="mb-3" ShowCloseIcon="true" CloseIconClicked="() => _message = string.Empty">@_message</MudAlert>
}

<MudTable Items="_summaries" Hover="true" Striped="true" Dense="true" Loading="_loading" Elevation="2">
    <HeaderContent>
        <MudTh>Agent</MudTh>
        <MudTh>Type</MudTh>
        <MudTh>Commission</MudTh>
        <MudTh Style="text-align:right">Effective Limit</MudTh>
        <MudTh Style="text-align:right">Available</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.BusinessName</MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Color="@(context.AgentType == "PayoutAgent" ? Color.Tertiary : Color.Primary)">
                @(context.AgentType == "PayoutAgent" ? "Payout" : "Sending")
            </MudChip>
        </MudTd>
        <MudTd>
            @if (!string.IsNullOrEmpty(context.CommissionMode))
            {
                <MudChip T="string" Size="Size.Small" Color="@(context.CommissionMode == "Percentage" ? Color.Info : Color.Warning)">
                    @(context.CommissionMode == "Percentage" ? $"{context.CommissionValue:N2}%" : $"Flat {context.CommissionValue:N2}")
                </MudChip>
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">Not set</MudText>
            }
        </MudTd>
        <MudTd Style="text-align:right"><strong>@context.EffectiveCreditLimit.ToString("N2")</strong></MudTd>
        <MudTd Style="text-align:right">
            <MudChip T="string" Size="Size.Small" Color="@(context.AvailableBalance >= 0 ? Color.Success : Color.Error)">
                @context.AvailableBalance.ToString("N2")
            </MudChip>
        </MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small"
                     Color="@(context.Status == "Approved" ? Color.Success : context.Status == "Blocked" ? Color.Error : Color.Warning)">
                @context.Status
            </MudChip>
        </MudTd>
        <MudTd>
            <MudTooltip Text="View Details">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Default"
                               OnClick="@(() => ViewAgentAccounting(context))" />
            </MudTooltip>
            @if (context.AgentType == "SendingAgent")
            {
                <MudTooltip Text="Adjust Limit">
                    <MudIconButton Icon="@Icons.Material.Filled.Tune" Size="Size.Small" Color="Color.Primary"
                                   OnClick="@(() => OpenAdjustPopup(context))" />
                </MudTooltip>
            }
            <MudTooltip Text="Commission">
                <MudIconButton Icon="@Icons.Material.Filled.Percent" Size="Size.Small" Color="Color.Secondary"
                               OnClick="@(() => OpenCommissionPopup(context))" />
            </MudTooltip>
            <MudTooltip Text="History">
                <MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" Color="Color.Info"
                               OnClick="@(() => ViewAdjustments(context))" />
            </MudTooltip>
        </MudTd>
    </RowTemplate>
</MudTable>

@* Agent Accounting Detail Popup *@
@if (_showDetailPopup && _detailAgent != null)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1300;" @onclick="@(() => _showDetailPopup = false)"></div>
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1400; width: 550px; max-width: 95vw;">
        <MudPaper Elevation="8" Class="pa-6" Style="border-radius: 12px;">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">@_detailAgent.BusinessName — Setup</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => _showDetailPopup = false)" />
            </div>
            <MudGrid>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Country</MudText><MudText>@_detailAgent.Country</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Currency</MudText><MudText>@_detailAgent.Currency</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Funding Type</MudText><MudText>@_detailAgent.FundingType</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Agent Type</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@(_detailAgent.AgentType == "PayoutAgent" ? Color.Tertiary : Color.Primary)">@(_detailAgent.AgentType == "PayoutAgent" ? "Payout Agent" : "Sending Agent")</MudChip>
                </MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@(_detailAgent.Status == "Approved" ? Color.Success : _detailAgent.Status == "Blocked" ? Color.Error : Color.Warning)">@_detailAgent.Status</MudChip>
                </MudItem>
            </MudGrid>
            <MudDivider Class="my-3" />
            <MudGrid>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Base Credit Limit</MudText><MudText>@_detailAgent.BaseCreditLimit.ToString("N2")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Effective Credit Limit</MudText><MudText><strong>@_detailAgent.EffectiveCreditLimit.ToString("N2")</strong></MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Current Balance</MudText><MudText>@_detailAgent.CurrentBalance.ToString("N2")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Available Balance</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@(_detailAgent.AvailableBalance >= 0 ? Color.Success : Color.Error)">@_detailAgent.AvailableBalance.ToString("N2")</MudChip>
                </MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Active Adjustments</MudText><MudText>@_detailAgent.ActiveAdjustments</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Commission</MudText>
                    @if (!string.IsNullOrEmpty(_detailAgent.CommissionMode))
                    {
                        <MudText>@(_detailAgent.CommissionMode == "Percentage" ? $"{_detailAgent.CommissionValue:N2}%" : $"Flat {_detailAgent.CommissionValue:N2}")</MudText>
                    }
                    else
                    {
                        <MudText Color="Color.Secondary">Not set</MudText>
                    }
                </MudItem>
            </MudGrid>
        </MudPaper>
    </div>
}

@* Adjust Limit Popup *@
@if (_showAdjustPopup)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1300;" @onclick="@(() => _showAdjustPopup = false)"></div>
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1400; width: 500px;">
        <MudPaper Elevation="8" Class="pa-6" Style="border-radius: 12px;">
            <MudText Typo="Typo.h6" Class="mb-4">Adjust Limit - @_selectedAgent?.BusinessName</MudText>

            @if (!string.IsNullOrEmpty(_formError))
            {
                <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true">@_formError</MudAlert>
            }

            <MudNumericField @bind-Value="_adjustAmount" Label="Amount (+ increase / - decrease) *" Variant="Variant.Outlined"
                             Format="N2" Class="mb-3" />

            <MudSelect @bind-Value="_adjustDuration" Label="Duration" Variant="Variant.Outlined" Class="mb-3" T="int?">
                <MudSelectItem T="int?" Value="@((int?)null)">Permanent</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)2)">2 Days</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)3)">3 Days</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)7)">7 Days</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)30)">30 Days</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)90)">90 Days</MudSelectItem>
            </MudSelect>

            <MudTextField @bind-Value="_adjustNotes" Label="Notes (optional)" Variant="Variant.Outlined" Lines="2" Class="mb-4" />

            <div class="d-flex justify-end gap-2">
                <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Close" OnClick="@(() => _showAdjustPopup = false)">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="CreateAdjustment">Save</MudButton>
            </div>
        </MudPaper>
    </div>
}

@* Agent Commission Setup Popup *@
@if (_showCommissionPopup)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1300;" @onclick="@(() => _showCommissionPopup = false)"></div>
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1400; width: 450px; max-width: 95vw;">
        <MudPaper Elevation="8" Class="pa-6" Style="border-radius: 12px;">
            <MudText Typo="Typo.h6" Class="mb-4">Agent Commission - @_selectedAgent?.BusinessName</MudText>

            @if (!string.IsNullOrEmpty(_commissionError))
            {
                <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true">@_commissionError</MudAlert>
            }

            <MudSelect T="string" @bind-Value="_commMode" Label="Commission Type *" Variant="Variant.Outlined" Class="mb-3">
                <MudSelectItem Value="@("Percentage")">Percentage</MudSelectItem>
                <MudSelectItem Value="@("Flat")">Flat</MudSelectItem>
            </MudSelect>

            @if (_commMode == "Percentage")
            {
                <MudNumericField T="decimal" @bind-Value="_commValue" Label="Commission Percentage (%)" Variant="Variant.Outlined"
                                 Min="0" Max="100" Class="mb-3" />
            }
            else
            {
                <MudNumericField T="decimal" @bind-Value="_commValue" Label="Flat Fee Amount" Variant="Variant.Outlined"
                                 Min="0" Class="mb-3" />
            }

            <div class="d-flex justify-end gap-2 mt-4">
                <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Close" OnClick="@(() => _showCommissionPopup = false)">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveCommission">Save</MudButton>
            </div>
        </MudPaper>
    </div>
}

@* History Popup *@
@if (_showHistoryPopup)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1300;" @onclick="@(() => _showHistoryPopup = false)"></div>
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1400; width: 750px; max-height: 80vh; overflow-y: auto;">
        <MudPaper Elevation="8" Class="pa-6" Style="border-radius: 12px;">
            <MudText Typo="Typo.h6" Class="mb-4">Adjustment History - @_selectedAgent?.BusinessName</MudText>

            <MudTable Items="_adjustments" Hover="true" Dense="true" Striped="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Amount</MudTh>
                    <MudTh>From</MudTh>
                    <MudTh>To</MudTh>
                    <MudTh>Notes</MudTh>
                    <MudTh>Active</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudText Color="@(context.Amount >= 0 ? Color.Success : Color.Error)">
                            @(context.Amount >= 0 ? "+" : "")@context.Amount.ToString("N2")
                        </MudText>
                    </MudTd>
                    <MudTd>@context.EffectiveFrom.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd>@(context.EffectiveTo?.ToString("yyyy-MM-dd") ?? "Permanent")</MudTd>
                    <MudTd>@(context.Notes ?? "-")</MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                            @(context.IsActive ? "Active" : "Inactive")
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        @if (context.IsActive)
                        {
                            <MudTooltip Text="Deactivate">
                                <MudIconButton Icon="@Icons.Material.Filled.Block" Size="Size.Small" Color="Color.Error"
                                               OnClick="@(() => DeactivateAdjustment(context.Id))" />
                            </MudTooltip>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <div class="d-flex justify-end mt-4">
                <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Close" OnClick="@(() => _showHistoryPopup = false)">Close</MudButton>
            </div>
        </MudPaper>
    </div>
}

@code {
    private List<AgentAccountingSummary> _summaries = new();
    private List<AgentLimitAdjustmentModel> _adjustments = new();
    private AgentAccountingSummary? _selectedAgent;

    private bool _loading;
    private bool _showAdjustPopup;
    private bool _showHistoryPopup;
    private bool _showCommissionPopup;
    private bool _showDetailPopup;
    private AgentAccountingSummary? _detailAgent;
    private string _message = string.Empty;
    private Severity _severity = Severity.Info;

    // Adjust limit fields
    private decimal _adjustAmount;
    private int? _adjustDuration;
    private string? _adjustNotes;
    private string _formError = string.Empty;

    // Commission fields
    private string _commMode = "Percentage";
    private decimal _commValue;
    private string _commissionError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await Auth.LoadFromSessionAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        var result = await Api.GetAccountingSummariesAsync();
        if (result?.Success == true)
            _summaries = result.Data ?? new();
        _loading = false;
    }

    private void ViewAgentAccounting(AgentAccountingSummary agent)
    {
        _detailAgent = agent;
        _showDetailPopup = true;
    }

    private void OpenAdjustPopup(AgentAccountingSummary agent)
    {
        _selectedAgent = agent;
        _adjustAmount = 0;
        _adjustDuration = null;
        _adjustNotes = null;
        _formError = string.Empty;
        _showAdjustPopup = true;
    }

    private async Task OpenCommissionPopup(AgentAccountingSummary agent)
    {
        _selectedAgent = agent;
        _commMode = "Percentage";
        _commValue = 0;
        _commissionError = string.Empty;

        // Load existing agent commission if any
        var existing = await Api.GetAgentCommissionAsync(agent.AgentId);
        if (existing?.Success == true && existing.Data != null)
        {
            _commMode = existing.Data.CommissionType;
            _commValue = existing.Data.CommissionValue;
        }

        _showCommissionPopup = true;
    }

    private async Task SaveCommission()
    {
        _commissionError = string.Empty;
        if (_selectedAgent == null) return;
        if (_commValue <= 0)
        { _commissionError = "Commission value must be greater than zero."; return; }
        if (_commMode == "Percentage" && _commValue > 100)
        { _commissionError = "Percentage cannot exceed 100%."; return; }

        var dto = new
        {
            agentId = _selectedAgent.AgentId,
            commissionType = _commMode,
            commissionValue = _commValue
        };

        var result = await Api.SaveAgentCommissionAsync(dto);
        if (result?.Success == true)
        {
            _message = $"Commission set for {_selectedAgent.BusinessName}.";
            _severity = Severity.Success;
            _showCommissionPopup = false;
            await LoadData();
        }
        else
        {
            _commissionError = result?.Message ?? "Failed to save commission.";
        }
    }

    private async Task CreateAdjustment()
    {
        _formError = string.Empty;
        if (_selectedAgent == null) return;

        if (_adjustAmount == 0)
        { _formError = "Amount cannot be zero."; return; }

        var result = await Api.CreateAdjustmentAsync(new
        {
            AgentId = _selectedAgent.AgentId,
            Amount = _adjustAmount,
            DurationDays = _adjustDuration,
            Notes = _adjustNotes
        });

        if (result?.Success == true)
        {
            _message = result.Message;
            _severity = Severity.Success;
            _showAdjustPopup = false;
            await LoadData();
        }
        else
        {
            _formError = result?.Message ?? "Failed to create adjustment.";
        }
    }

    private async Task ViewAdjustments(AgentAccountingSummary agent)
    {
        _selectedAgent = agent;
        var result = await Api.GetAgentAdjustmentsAsync(agent.AgentId);
        if (result?.Success == true)
            _adjustments = result.Data ?? new();
        _showHistoryPopup = true;
    }

    private async Task DeactivateAdjustment(long id)
    {
        var result = await Api.DeactivateAdjustmentAsync(id);
        if (result?.Success == true)
        {
            _message = "Adjustment deactivated.";
            _severity = Severity.Success;
            if (_selectedAgent != null)
                await ViewAdjustments(_selectedAgent);
            await LoadData();
        }
        else
        {
            _message = result?.Message ?? "Failed to deactivate.";
            _severity = Severity.Error;
        }
    }

}
