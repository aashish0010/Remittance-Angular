@page "/admin/rates"
@using Remittance.Web.Client.Models
@using Remittance.Web.Client.Services

<PageTitle>Exchange Rates - Remittance</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h5" Style="font-weight: 700;">Exchange Rate Management</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="@(() => { _editId = null; _newSource = "USD"; _newDest = "NPR"; _newRate = 0; _newMargin = null; _newAgentId = 0; _newCountry = null; _formError = string.Empty; _payoutAgentName = string.Empty; _showForm = true; })">
        Add Rate
    </MudButton>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <MudAlert Severity="@_msgSev" Class="mb-4" Dense="true" ShowCloseIcon="true"
              CloseIconClicked="@(() => _message = string.Empty)">@_message</MudAlert>
}

<MudPaper Elevation="4" Class="rounded-lg">
    <MudTable Items="_rates" Hover="true" Striped="true" Dense="true" Loading="_loading">
        <HeaderContent>
            <MudTh>Pair</MudTh>
            <MudTh>Rate</MudTh>
            <MudTh>Payout Partner</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="Color.Primary">@context.SourceCurrency</MudChip>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Style="vertical-align: middle;" />
                <MudChip T="string" Size="Size.Small" Color="Color.Secondary">@context.DestinationCurrency</MudChip>
            </MudTd>
            <MudTd><strong>@context.Rate.ToString("N4")</strong></MudTd>
            <MudTd>@context.AgentName</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                    @(context.IsActive ? "Active" : "Expired")
                </MudChip>
            </MudTd>
            <MudTd>
                <MudTooltip Text="View Details">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Info"
                                   OnClick="@(() => ViewRate(context))" />
                </MudTooltip>
                <MudTooltip Text="Edit">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                   OnClick="@(() => StartEdit(context))" />
                </MudTooltip>
                <MudTooltip Text="Delete">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => DeleteRate(context))" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudPaper>

@* Rate Detail Popup *@
@if (_showDetailPopup && _detailRate != null)
{
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="9999" OnClick="@(() => _showDetailPopup = false)" />
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 10000; width: 480px; max-width: 95vw;">
        <MudPaper Elevation="12" Class="pa-6 rounded-lg">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Exchange Rate Details</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => _showDetailPopup = false)" />
            </div>
            <MudGrid Spacing="3">
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Source Currency</MudText><MudText>@_detailRate.SourceCurrency</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Destination Currency</MudText><MudText>@_detailRate.DestinationCurrency</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Rate</MudText><MudText><strong>@_detailRate.Rate.ToString("N4")</strong></MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Margin</MudText><MudText>@(_detailRate.Margin?.ToString("N2") ?? "-")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Payout Partner</MudText><MudText>@_detailRate.AgentName</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Country</MudText><MudText>@(string.IsNullOrEmpty(_detailRate.Country) ? "All" : _detailRate.Country)</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Effective From</MudText><MudText>@_detailRate.EffectiveFrom.ToString("yyyy-MM-dd HH:mm")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@(_detailRate.IsActive ? Color.Success : Color.Default)">@(_detailRate.IsActive ? "Active" : "Expired")</MudChip>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </div>
}

@if (_showForm)
{
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="9999" OnClick="@(() => _showForm = false)" />
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 10000; width: 620px; max-width: 95vw; max-height: 90vh; overflow-y: auto;">
        <MudPaper Elevation="12" Class="pa-6 rounded-lg">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">@(_editId.HasValue ? "Edit" : "Add") Exchange Rate</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => _showForm = false)" />
            </div>
            @if (!string.IsNullOrEmpty(_formError))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_formError</MudAlert>
            }

            <MudGrid Spacing="3">
                <MudItem xs="6">
                    <MudAutocomplete T="string" Value="_payoutAgentName" ValueChanged="OnPayoutAgentChanged"
                                     Label="Payout Partner *" SearchFunc="SearchPayoutAgentNames"
                                     Variant="Variant.Outlined" Dense="true" MinCharacters="0" />
                </MudItem>
                <MudItem xs="6">
                    <MudSelect T="string" @bind-Value="_newCountry" Label="Country (optional)"
                               Variant="Variant.Outlined" Clearable="true" Dense="true">
                        @foreach (var c in _countryList) { <MudSelectItem Value="@c">@c</MudSelectItem> }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />

            <MudGrid Spacing="3">
                <MudItem xs="6">
                    <MudSelect T="string" @bind-Value="_newSource" Label="Source Currency *"
                               Variant="Variant.Outlined" Dense="true">
                        @foreach (var c in _currencies) { <MudSelectItem Value="@c">@c</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <MudSelect T="string" @bind-Value="_newDest" Label="Destination Currency *"
                               Variant="Variant.Outlined" Dense="true">
                        @foreach (var c in _currencies) { <MudSelectItem Value="@c">@c</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <MudNumericField T="decimal" @bind-Value="_newRate" Label="Rate *" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudNumericField T="decimal?" @bind-Value="_newMargin" Label="Margin" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
            <div class="d-flex justify-end gap-2 mt-4">
                <MudButton StartIcon="@Icons.Material.Filled.Close" OnClick="@(() => _showForm = false)">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveRate" Disabled="_saving">
                    @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Save
                </MudButton>
            </div>
        </MudPaper>
    </div>
}

@code {
    private List<ExchangeRateModel> _rates = new();
    private List<AgentModel> _agents = new();
    private bool _loading = true;
    private bool _showForm;
    private bool _saving;
    private int? _editId;
    private string _newSource = "USD";
    private string _newDest = "NPR";
    private decimal _newRate;
    private decimal? _newMargin;
    private int _newAgentId;
    private string? _newCountry;
    private string _message = string.Empty;
    private string _formError = string.Empty;
    private Severity _msgSev = Severity.Info;
    private bool _showDetailPopup;
    private ExchangeRateModel? _detailRate;

    [Inject] private ApiService Api { get; set; } = null!;
    [Inject] private AuthStateService Auth { get; set; } = null!;

    private List<string> _currencies = new();
    private List<string> _countryList = new();
    private string _payoutAgentName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await Auth.LoadFromSessionAsync();
        await Task.WhenAll(LoadAgents(), LoadReferenceData(), LoadRates());
    }

    private async Task LoadReferenceData()
    {
        try
        {
            var cr = await Api.GetCountriesAsync();
            var cu = await Api.GetCurrenciesAsync();
            if (cr?.Success == true && cr.Data != null)
                _countryList = cr.Data.Select(c => c.Name).ToList();
            if (cu?.Success == true && cu.Data != null)
                _currencies = cu.Data;
        }
        catch { }
    }

    private async Task LoadAgents()
    {
        try
        {
            var result = await Api.GetAgentsAsync();
            if (result?.Success == true && result.Data != null)
                _agents = result.Data;
        }
        catch { }
    }

    private async Task LoadRates()
    {
        _loading = true;
        try
        {
            var result = await Api.GetRatesAsync();
            if (result?.Success == true && result.Data != null)
                _rates = result.Data;
            else
            {
                _rates = new();
                _message = result?.Message ?? "Failed to load exchange rates.";
                _msgSev = Severity.Error;
            }
        }
        catch (Exception ex)
        {
            _rates = new();
            _message = $"Could not connect to server: {ex.Message}";
            _msgSev = Severity.Error;
        }
        finally { _loading = false; }
    }

    private Task<IEnumerable<string>> SearchPayoutAgentNames(string value, CancellationToken _)
        => Task.FromResult(_agents.Where(a => a.AgentType == "PayoutAgent" && a.Status == "Approved")
            .Where(a => string.IsNullOrEmpty(value) || a.BusinessName.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Select(a => a.BusinessName));

    private void OnPayoutAgentChanged(string name)
    {
        _payoutAgentName = name;
        _newAgentId = _agents.FirstOrDefault(a => a.BusinessName == name)?.Id ?? 0;
    }

    private Task<IEnumerable<int>> SearchPayoutAgents(string value, CancellationToken token)
        => Task.FromResult(_agents.Where(a => a.AgentType == "PayoutAgent" && a.Status == "Approved")
            .Where(a => string.IsNullOrEmpty(value) || a.BusinessName.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Select(a => a.Id));

    private bool SearchPayoutAgentItem(string search, int id)
        => string.IsNullOrEmpty(search) || (_agents.FirstOrDefault(a => a.Id == id)?.BusinessName?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false);

    private Task<IEnumerable<string>> SearchCountries(string value, CancellationToken token)
        => Task.FromResult(string.IsNullOrEmpty(value)
            ? _countryList.AsEnumerable()
            : _countryList.Where(c => c.Contains(value, StringComparison.OrdinalIgnoreCase)));

    private Task<IEnumerable<string>> SearchCurrencies(string value, CancellationToken token)
        => Task.FromResult(string.IsNullOrEmpty(value)
            ? _currencies.AsEnumerable()
            : _currencies.Where(c => c.Contains(value, StringComparison.OrdinalIgnoreCase)));

    private void ViewRate(ExchangeRateModel rate)
    {
        _detailRate = rate;
        _showDetailPopup = true;
    }

    private void StartEdit(ExchangeRateModel rate)
    {
        _editId = rate.Id;
        _newSource = rate.SourceCurrency;
        _newDest = rate.DestinationCurrency;
        _newRate = rate.Rate;
        _newMargin = rate.Margin;
        _newAgentId = rate.AgentId;
        _payoutAgentName = rate.AgentName ?? string.Empty;
        _newCountry = rate.Country;
        _formError = string.Empty;
        _showForm = true;
    }

    private async Task SaveRate()
    {
        _formError = string.Empty;
        if (_newAgentId == 0) { _formError = "Payout partner is required."; return; }
        if (_newSource == _newDest) { _formError = "Source and destination currencies must be different."; return; }
        if (_newRate <= 0) { _formError = "Rate must be greater than zero."; return; }

        _saving = true;
        try
        {
            var dto = new
            {
                sourceCurrency = _newSource,
                destinationCurrency = _newDest,
                rate = _newRate,
                margin = _newMargin,
                effectiveFrom = DateTime.UtcNow,
                agentId = _newAgentId,
                country = _newCountry
            };

            if (_editId.HasValue)
            {
                var result = await Api.UpdateRateAsync(_editId.Value, dto);
                if (result?.Success == true)
                {
                    _message = "Exchange rate updated!"; _msgSev = Severity.Success;
                    _showForm = false; await LoadRates();
                }
                else { _formError = result?.Message ?? "Failed to update rate."; }
            }
            else
            {
                var result = await Api.CreateRateAsync(dto);
                if (result?.Success == true)
                {
                    _message = "Exchange rate created!"; _msgSev = Severity.Success;
                    _showForm = false; await LoadRates();
                }
                else { _formError = result?.Message ?? "Failed to create rate."; }
            }
        }
        catch (Exception ex) { _message = $"Error: {ex.Message}"; _msgSev = Severity.Error; }
        finally { _saving = false; }
    }

    private async Task DeleteRate(ExchangeRateModel rate)
    {
        try
        {
            var result = await Api.DeleteRateAsync(rate.Id);
            if (result?.Success == true)
            {
                _message = $"Rate {rate.SourceCurrency}/{rate.DestinationCurrency} deleted.";
                _msgSev = Severity.Success;
                await LoadRates();
            }
            else { _message = result?.Message ?? "Failed to delete rate."; _msgSev = Severity.Error; }
        }
        catch (Exception ex) { _message = $"Error: {ex.Message}"; _msgSev = Severity.Error; }
    }
}
