@page "/admin/compliance-setup"
@using Remittance.Web.Client.Models
@using Remittance.Web.Client.Services
@inject ApiService Api
@inject AuthStateService Auth

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h5" Style="font-weight: 700;">Compliance Rule Setup</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreatePopup">
        Add Rule
    </MudButton>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <MudAlert Severity="@_severity" Class="mb-3" ShowCloseIcon="true" CloseIconClicked="() => _message = string.Empty">@_message</MudAlert>
}

<MudPaper Elevation="4" Class="rounded-lg">
    <MudTable Items="_rules" Hover="true" Striped="true" Dense="true" Loading="_loading">
        <HeaderContent>
            <MudTh>Rule Name</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Threshold</MudTh>
            <MudTh>Frequency</MudTh>
            <MudTh>Countries</MudTh>
            <MudTh>Action</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.RuleName</MudTd>
            <MudTd><MudChip T="string" Size="Size.Small" Color="@GetTypeColor(context.RuleType)">@context.RuleType</MudChip></MudTd>
            <MudTd>@(context.ThresholdAmount?.ToString("N2") ?? "-")</MudTd>
            <MudTd>
                @if (context.MaxTransactionCount.HasValue)
                {
                    <span>@context.MaxTransactionCount txns / @(context.TimePeriodDays ?? 0) days</span>
                }
                else
                {
                    <span>-</span>
                }
            </MudTd>
            <MudTd>
                @if (!string.IsNullOrEmpty(context.SourceCountry) || !string.IsNullOrEmpty(context.DestinationCountry))
                {
                    <span>@(context.SourceCountry ?? "*") → @(context.DestinationCountry ?? "*")</span>
                }
                else
                {
                    <span>-</span>
                }
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.Action == "Block" ? Color.Error : context.Action == "Review" ? Color.Warning : Color.Info)">
                    @context.Action
                </MudChip>
            </MudTd>
            <MudTd>
                <MudSwitch T="bool" Value="context.IsActive" Color="Color.Success"
                           ValueChanged="() => ToggleRule(context)" />
            </MudTd>
            <MudTd>
                <MudTooltip Text="Edit">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                   OnClick="() => OpenEditPopup(context)" />
                </MudTooltip>
                <MudTooltip Text="Delete">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="() => DeleteRule(context.Id)" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudPaper>

@* Create/Edit Popup *@
@if (_showPopup)
{
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="9999" OnClick="() => _showPopup = false" />
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 10000; width: 580px; max-width: 95vw; max-height: 90vh; overflow-y: auto;">
        <MudPaper Elevation="12" Class="pa-6 rounded-lg">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">@(_editingId > 0 ? "Edit Rule" : "Create Rule")</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => _showPopup = false" />
            </div>

            @if (!string.IsNullOrEmpty(_formError))
            {
                <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true">@_formError</MudAlert>
            }

            <MudTextField @bind-Value="_ruleName" Label="Rule Name *" Variant="Variant.Outlined" Class="mb-3" />

            <MudSelect @bind-Value="_ruleType" Label="Rule Type *" Variant="Variant.Outlined" Class="mb-3" T="string">
                <MudSelectItem T="string" Value="@("AmountThreshold")">Amount Threshold</MudSelectItem>
                <MudSelectItem T="string" Value="@("FrequencyLimit")">Frequency Limit</MudSelectItem>
                <MudSelectItem T="string" Value="@("CountryRestriction")">Country Restriction</MudSelectItem>
                <MudSelectItem T="string" Value="@("NameScreening")">Name Screening</MudSelectItem>
            </MudSelect>

            @if (_ruleType == "AmountThreshold")
            {
                <MudNumericField @bind-Value="_thresholdAmount" Label="Threshold Amount *" Variant="Variant.Outlined" Format="N2" Class="mb-3" T="decimal?" />
            }

            @if (_ruleType == "FrequencyLimit")
            {
                <MudGrid Spacing="3" Class="mb-3">
                    <MudItem xs="6">
                        <MudNumericField @bind-Value="_maxTransactionCount" Label="Max Transactions *" Variant="Variant.Outlined" T="int?" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField @bind-Value="_timePeriodDays" Label="Time Period (Days) *" Variant="Variant.Outlined" T="int?" />
                    </MudItem>
                </MudGrid>
            }

            @if (_ruleType == "CountryRestriction")
            {
                <MudGrid Spacing="3" Class="mb-3">
                    <MudItem xs="6">
                        <MudSelect T="string" @bind-Value="_sourceCountry" Label="Source Country (* for all)"
                                   Variant="Variant.Outlined" Dense="true" Clearable="true">
                            <MudSelectItem Value="@("*")">* (All)</MudSelectItem>
                            @foreach (var c in _countries) { <MudSelectItem Value="@c">@c</MudSelectItem> }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6">
                        <MudSelect T="string" @bind-Value="_destCountry" Label="Destination Country (* for all)"
                                   Variant="Variant.Outlined" Dense="true" Clearable="true">
                            <MudSelectItem Value="@("*")">* (All)</MudSelectItem>
                            @foreach (var c in _countries) { <MudSelectItem Value="@c">@c</MudSelectItem> }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            }

            <MudSelect @bind-Value="_ruleAction" Label="Action *" Variant="Variant.Outlined" Class="mb-3" T="string">
                <MudSelectItem T="string" Value="@("Flag")">Flag</MudSelectItem>
                <MudSelectItem T="string" Value="@("Block")">Block</MudSelectItem>
                <MudSelectItem T="string" Value="@("Review")">Review</MudSelectItem>
            </MudSelect>

            <MudSwitch @bind-Value="_ruleActive" Label="Active" Color="Color.Success" Class="mb-4" T="bool" />

            <div class="d-flex justify-end gap-2">
                <MudButton StartIcon="@Icons.Material.Filled.Close" OnClick="() => _showPopup = false">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveRule">Save</MudButton>
            </div>
        </MudPaper>
    </div>
}

@code {
    private List<ComplianceRuleModel> _rules = new();
    private bool _loading;
    private bool _showPopup;
    private string _message = string.Empty;
    private Severity _severity = Severity.Info;

    private int _editingId;
    private string _ruleName = string.Empty;
    private string _ruleType = "AmountThreshold";
    private decimal? _thresholdAmount;
    private int? _timePeriodDays;
    private int? _maxTransactionCount;
    private string? _sourceCountry;
    private string? _destCountry;
    private string _ruleAction = "Flag";
    private bool _ruleActive = true;
    private string _formError = string.Empty;

    private List<string> _countries = new();

    protected override async Task OnInitializedAsync()
    {
        await Auth.LoadFromSessionAsync();
        await Task.WhenAll(LoadReferenceData(), LoadRules());
    }

    private async Task LoadReferenceData()
    {
        try
        {
            var cr = await Api.GetCountriesAsync();
            if (cr?.Success == true && cr.Data != null)
                _countries = cr.Data.Select(c => c.Name).ToList();
        }
        catch { }
    }

    private Task<IEnumerable<string>> SearchCountriesWithAll(string value, CancellationToken token)
    {
        var all = new[] { "*" }.Concat(_countries);
        return Task.FromResult(string.IsNullOrEmpty(value)
            ? all
            : all.Where(c => c.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }

    private async Task LoadRules()
    {
        _loading = true;
        var result = await Api.GetComplianceRulesAsync();
        if (result?.Success == true)
            _rules = result.Data ?? new();
        _loading = false;
    }

    private void OpenCreatePopup()
    {
        _editingId = 0;
        _ruleName = string.Empty;
        _ruleType = "AmountThreshold";
        _thresholdAmount = null;
        _timePeriodDays = null;
        _maxTransactionCount = null;
        _sourceCountry = null;
        _destCountry = null;
        _ruleAction = "Flag";
        _ruleActive = true;
        _formError = string.Empty;
        _showPopup = true;
    }

    private void OpenEditPopup(ComplianceRuleModel rule)
    {
        _editingId = rule.Id;
        _ruleName = rule.RuleName;
        _ruleType = rule.RuleType;
        _thresholdAmount = rule.ThresholdAmount;
        _timePeriodDays = rule.TimePeriodDays;
        _maxTransactionCount = rule.MaxTransactionCount;
        _sourceCountry = rule.SourceCountry;
        _destCountry = rule.DestinationCountry;
        _ruleAction = rule.Action;
        _ruleActive = rule.IsActive;
        _formError = string.Empty;
        _showPopup = true;
    }

    private async Task SaveRule()
    {
        _formError = string.Empty;

        if (string.IsNullOrWhiteSpace(_ruleName))
        { _formError = "Rule name is required."; return; }

        if (string.IsNullOrWhiteSpace(_ruleType))
        { _formError = "Rule type is required."; return; }

        if (_ruleType == "AmountThreshold" && (_thresholdAmount == null || _thresholdAmount <= 0))
        { _formError = "Threshold amount must be greater than zero."; return; }

        if (_ruleType == "FrequencyLimit")
        {
            if (_maxTransactionCount == null || _maxTransactionCount <= 0)
            { _formError = "Max transaction count must be greater than zero."; return; }
            if (_timePeriodDays == null || _timePeriodDays <= 0)
            { _formError = "Time period (days) must be greater than zero."; return; }
        }

        if (string.IsNullOrWhiteSpace(_ruleAction))
        { _formError = "Action is required."; return; }

        var dto = new
        {
            RuleName = _ruleName,
            RuleType = _ruleType,
            ThresholdAmount = _thresholdAmount,
            TimePeriodDays = _timePeriodDays,
            MaxTransactionCount = _maxTransactionCount,
            SourceCountry = _sourceCountry,
            DestinationCountry = _destCountry,
            Action = _ruleAction,
            IsActive = _ruleActive
        };

        if (_editingId > 0)
        {
            var result = await Api.UpdateComplianceRuleAsync(_editingId, dto);
            if (result?.Success == true)
            {
                _message = "Rule updated."; _severity = Severity.Success;
                _showPopup = false;
                await LoadRules();
            }
            else
            { _formError = result?.Message ?? "Failed to update rule."; }
        }
        else
        {
            var result = await Api.CreateComplianceRuleAsync(dto);
            if (result?.Success == true)
            {
                _message = "Rule created."; _severity = Severity.Success;
                _showPopup = false;
                await LoadRules();
            }
            else
            { _formError = result?.Message ?? "Failed to create rule."; }
        }
    }

    private async Task DeleteRule(int id)
    {
        var result = await Api.DeleteComplianceRuleAsync(id);
        _message = result?.Success == true ? "Rule deleted." : (result?.Message ?? "Failed.");
        _severity = result?.Success == true ? Severity.Success : Severity.Error;
        await LoadRules();
    }

    private async Task ToggleRule(ComplianceRuleModel rule)
    {
        var result = await Api.ToggleComplianceRuleAsync(rule.Id);
        if (result?.Success == true)
        {
            rule.IsActive = !rule.IsActive;
            _message = result.Message;
            _severity = Severity.Success;
        }
    }

    private static Color GetTypeColor(string type) => type switch
    {
        "AmountThreshold" => Color.Error,
        "FrequencyLimit" => Color.Warning,
        "CountryRestriction" => Color.Info,
        "NameScreening" => Color.Secondary,
        _ => Color.Default
    };
}
