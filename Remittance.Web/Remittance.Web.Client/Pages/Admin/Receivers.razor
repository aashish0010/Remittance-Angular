@page "/admin/receivers"
@using Remittance.Web.Client.Models
@using Remittance.Web.Client.Services
@inject ApiService Api
@inject AuthStateService Auth

<MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 700;">Receivers</MudText>

@if (!string.IsNullOrEmpty(_message))
{
    <MudAlert Severity="@_severity" Class="mb-3" ShowCloseIcon="true" CloseIconClicked="() => _message = string.Empty">@_message</MudAlert>
}

<MudGrid Class="mb-3">
    <MudItem xs="12" sm="4">
        <MudTextField @bind-Value="_filterSearch" Label="Search Customer" Variant="Variant.Outlined"
                      Placeholder="Type name or phone..." Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.Search" OnAdornmentClick="FilterBySearch" />
    </MudItem>
    <MudItem xs="12" sm="2" Class="d-flex align-end">
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.FilterAlt" OnClick="FilterBySearch">Filter</MudButton>
        @if (_filterCustomerId.HasValue)
        {
            <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearFilter" Class="ml-2">Clear</MudButton>
        }
    </MudItem>
    <MudItem xs="12" sm="6" Class="d-flex align-end justify-end">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="OpenCreatePopup">Add Receiver</MudButton>
    </MudItem>
</MudGrid>

@if (_filterCustomerId.HasValue)
{
    <MudAlert Severity="Severity.Info" Class="mb-3" Dense="true" ShowCloseIcon="true" CloseIconClicked="ClearFilter">
        Filtered by: @(_customers.FirstOrDefault(c => c.Id == _filterCustomerId)?.FullName ?? "Unknown")
    </MudAlert>
}

<MudTable Items="_receivers" Hover="true" Striped="true" Dense="true" Loading="_loading" Elevation="2">
    <HeaderContent>
        <MudTh>Customer</MudTh>
        <MudTh>Receiver</MudTh>
        <MudTh>Country</MudTh>
        <MudTh>Bank</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.CustomerName</MudTd>
        <MudTd>@context.FullName</MudTd>
        <MudTd>@context.Country</MudTd>
        <MudTd>@(context.BankName ?? "-")</MudTd>
        <MudTd>
            <MudTooltip Text="View Details">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Info" OnClick="@(() => ViewReceiver(context))" />
            </MudTooltip>
            <MudTooltip Text="Edit">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="@(() => OpenEditPopup(context))" />
            </MudTooltip>
            <MudTooltip Text="Delete">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteReceiver(context.Id))" />
            </MudTooltip>
        </MudTd>
    </RowTemplate>
</MudTable>

@* Receiver Detail Popup *@
@if (_showDetail && _detailReceiver != null)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1300;" @onclick="@(() => _showDetail = false)"></div>
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1400; width: 500px; max-width: 95vw;">
        <MudPaper Elevation="8" Class="pa-6" Style="border-radius: 12px;">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Receiver Details</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => _showDetail = false)" />
            </div>
            <MudGrid>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Customer</MudText><MudText>@_detailReceiver.CustomerName</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Receiver Name</MudText><MudText>@_detailReceiver.FullName</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Phone</MudText><MudText>@_detailReceiver.Phone</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Email</MudText><MudText>@(_detailReceiver.Email ?? "-")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Country</MudText><MudText>@_detailReceiver.Country</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">City</MudText><MudText>@(_detailReceiver.City ?? "-")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Bank</MudText><MudText>@(_detailReceiver.BankName ?? "-")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Account</MudText><MudText>@(_detailReceiver.AccountNumber ?? "-")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Relationship</MudText><MudText>@(_detailReceiver.Relationship ?? "-")</MudText></MudItem>
            </MudGrid>
        </MudPaper>
    </div>
}

@* Customer Search Modal *@
@if (_showCustomerSearch)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 9999;" @onclick="() => _showCustomerSearch = false"></div>
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 10000; width: 550px; max-height: 80vh;">
        <MudPaper Elevation="8" Class="pa-6" Style="border-radius: 12px;">
            <MudText Typo="Typo.h6" Class="mb-3">Search Customer</MudText>

            <div class="d-flex gap-2 mb-3">
                <MudTextField @bind-Value="_customerSearchText" Label="Name or Phone" Variant="Variant.Outlined"
                              Placeholder="Type to search..." Class="flex-grow-1"
                              Immediate="true" OnKeyDown="OnSearchKeyDown" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" OnClick="SearchCustomers"
                           Style="height: 56px;">Search</MudButton>
            </div>

            @if (_customerSearchResults.Any())
            {
                <MudList T="CustomerModel" Dense="true" Style="max-height: 300px; overflow-y: auto;">
                    @foreach (var c in _customerSearchResults)
                    {
                        <MudListItem T="CustomerModel" OnClick="() => SelectCustomer(c)"
                                     Style="cursor: pointer; border-bottom: 1px solid var(--mud-palette-lines-default);">
                            <div class="d-flex justify-space-between align-center">
                                <div>
                                    <MudText Typo="Typo.body1" Style="font-weight: 600;">@c.FullName</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@c.Phone — @c.Country</MudText>
                                </div>
                                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
            else if (_searchPerformed)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">No customers found.</MudText>
            }

            <div class="d-flex justify-end mt-3">
                <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Close" OnClick="() => _showCustomerSearch = false">Cancel</MudButton>
            </div>
        </MudPaper>
    </div>
}

@* Create/Edit Popup *@
@if (_showPopup)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1300;" @onclick="() => _showPopup = false"></div>
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1400; width: 550px;">
        <MudPaper Elevation="8" Class="pa-6" Style="border-radius: 12px;">
            <MudText Typo="Typo.h6" Class="mb-4">@(_editingId > 0 ? "Edit Receiver" : "Add Receiver")</MudText>

            @if (!string.IsNullOrEmpty(_formError))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">@_formError</MudAlert>
            }

            @* Customer selector *@
            <div class="d-flex gap-2 mb-3 align-center">
                <MudTextField Value="@_selectedCustomerName" Label="Customer *" Variant="Variant.Outlined"
                              ReadOnly="true" Class="flex-grow-1" />
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonSearch" OnClick="OpenCustomerSearch"
                           Style="height: 56px;">Browse</MudButton>
            </div>

            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_fullName" Label="Full Name *" Variant="Variant.Outlined"
                                  Required="true" RequiredError="Full name is required" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_phone" Label="Phone *" Variant="Variant.Outlined"
                                  Required="true" RequiredError="Phone is required" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined" InputType="InputType.Email" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="_country" Label="Country *" Variant="Variant.Outlined">
                        @foreach (var c in _countries) { <MudSelectItem Value="@c">@c</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_city" Label="City" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_relationship" Label="Relationship" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_bankName" Label="Bank Name" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_accountNumber" Label="Account Number" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>

            <div class="d-flex justify-end gap-2 mt-4">
                <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Close" OnClick="() => _showPopup = false">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveReceiver">Save</MudButton>
            </div>
        </MudPaper>
    </div>
}

@code {
    private List<ReceiverModel> _receivers = new();
    private List<CustomerModel> _customers = new();
    private bool _loading;
    private bool _showPopup;
    private bool _showCustomerSearch;
    private string _message = string.Empty;
    private string _formError = string.Empty;
    private Severity _severity = Severity.Info;
    private int? _filterCustomerId;
    private string _filterSearch = string.Empty;

    // Customer search
    private string _customerSearchText = string.Empty;
    private List<CustomerModel> _customerSearchResults = new();
    private bool _searchPerformed;
    private string _selectedCustomerName = string.Empty;

    private List<string> _countries = new();
    private bool _showDetail;
    private ReceiverModel? _detailReceiver;

    private int _editingId;
    private int _customerId;
    private string _fullName = string.Empty;
    private string _phone = string.Empty;
    private string? _email;
    private string _country = string.Empty;
    private string? _city;
    private string? _bankName;
    private string? _accountNumber;
    private string? _relationship;

    protected override async Task OnInitializedAsync()
    {
        await Auth.LoadFromSessionAsync();
        await Task.WhenAll(LoadCustomers(), LoadReferenceData(), LoadReceivers());
    }

    private async Task LoadReferenceData()
    {
        try
        {
            var cr = await Api.GetCountriesAsync();
            if (cr?.Success == true && cr.Data != null)
                _countries = cr.Data.Select(c => c.Name).ToList();
        }
        catch { }
    }

    private Task<IEnumerable<string>> SearchCountries(string value, CancellationToken token)
        => Task.FromResult(string.IsNullOrEmpty(value)
            ? _countries.AsEnumerable()
            : _countries.Where(c => c.Contains(value, StringComparison.OrdinalIgnoreCase)));

    private async Task LoadCustomers()
    {
        var result = await Api.GetCustomersAsync();
        if (result?.Success == true)
            _customers = result.Data ?? new();
    }

    private async Task LoadReceivers()
    {
        _loading = true;
        var result = await Api.GetReceiversAsync();
        if (result?.Success == true)
            _receivers = result.Data ?? new();
        _loading = false;
    }

    private async Task FilterBySearch()
    {
        if (string.IsNullOrWhiteSpace(_filterSearch))
        {
            _filterCustomerId = null;
            await LoadReceivers();
            return;
        }

        var match = _customers.FirstOrDefault(c =>
            c.FullName.Contains(_filterSearch, StringComparison.OrdinalIgnoreCase) ||
            (c.Phone != null && c.Phone.Contains(_filterSearch, StringComparison.OrdinalIgnoreCase)));

        if (match != null)
        {
            _filterCustomerId = match.Id;
            _loading = true;
            var result = await Api.GetReceiversByCustomerAsync(match.Id);
            if (result?.Success == true)
                _receivers = result.Data ?? new();
            _loading = false;
        }
        else
        {
            _message = "No matching customer found.";
            _severity = Severity.Warning;
        }
    }

    private async Task ClearFilter()
    {
        _filterCustomerId = null;
        _filterSearch = string.Empty;
        await LoadReceivers();
    }

    private void ViewReceiver(ReceiverModel r)
    {
        _detailReceiver = r;
        _showDetail = true;
    }

    private void OpenCustomerSearch()
    {
        _customerSearchText = string.Empty;
        _customerSearchResults = new();
        _searchPerformed = false;
        _showCustomerSearch = true;
    }

    private void SearchCustomers()
    {
        _searchPerformed = true;
        if (string.IsNullOrWhiteSpace(_customerSearchText))
        {
            _customerSearchResults = new();
            return;
        }

        _customerSearchResults = _customers.Where(c =>
            c.FullName.Contains(_customerSearchText, StringComparison.OrdinalIgnoreCase) ||
            (c.Phone != null && c.Phone.Contains(_customerSearchText, StringComparison.OrdinalIgnoreCase))
        ).ToList();
    }

    private void OnSearchKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            SearchCustomers();
    }

    private void SelectCustomer(CustomerModel c)
    {
        _customerId = c.Id;
        _selectedCustomerName = c.FullName;
        _showCustomerSearch = false;
    }

    private void OpenCreatePopup()
    {
        _editingId = 0;
        _customerId = 0;
        _selectedCustomerName = string.Empty;
        _fullName = string.Empty; _phone = string.Empty; _email = null;
        _country = string.Empty; _city = null; _bankName = null; _accountNumber = null; _relationship = null;
        _formError = string.Empty;
        _showPopup = true;
    }

    private void OpenEditPopup(ReceiverModel r)
    {
        _editingId = r.Id;
        _customerId = r.CustomerId;
        _selectedCustomerName = r.CustomerName;
        _fullName = r.FullName; _phone = r.Phone; _email = r.Email;
        _country = r.Country; _city = r.City; _bankName = r.BankName;
        _accountNumber = r.AccountNumber; _relationship = r.Relationship;
        _formError = string.Empty;
        _showPopup = true;
    }

    private async Task SaveReceiver()
    {
        _formError = string.Empty;
        if (string.IsNullOrWhiteSpace(_fullName))
        { _formError = "Full Name is required."; return; }
        if (string.IsNullOrWhiteSpace(_phone))
        { _formError = "Phone is required."; return; }
        if (string.IsNullOrWhiteSpace(_country))
        { _formError = "Country is required."; return; }
        if (_customerId <= 0)
        { _formError = "Please select a customer using the Browse button."; return; }

        var dto = new
        {
            CustomerId = _customerId,
            FullName = _fullName,
            Phone = _phone,
            Email = _email,
            Country = _country,
            City = _city,
            BankName = _bankName,
            AccountNumber = _accountNumber,
            Relationship = _relationship
        };

        if (_editingId > 0)
        {
            var result = await Api.UpdateReceiverAsync(_editingId, dto);
            if (result?.Success == true)
            {
                _message = "Receiver updated."; _severity = Severity.Success;
                _showPopup = false;
                await LoadReceivers();
            }
            else
            { _formError = result?.Message ?? "Failed to update receiver."; }
        }
        else
        {
            var result = await Api.CreateReceiverAsync(dto);
            if (result?.Success == true)
            {
                _message = "Receiver created."; _severity = Severity.Success;
                _showPopup = false;
                await LoadReceivers();
            }
            else
            { _formError = result?.Message ?? "Failed to create receiver."; }
        }
    }

    private async Task DeleteReceiver(int id)
    {
        var result = await Api.DeleteReceiverAsync(id);
        _message = result?.Success == true ? "Receiver deleted." : (result?.Message ?? "Failed.");
        _severity = result?.Success == true ? Severity.Success : Severity.Error;
        await LoadReceivers();
    }
}
