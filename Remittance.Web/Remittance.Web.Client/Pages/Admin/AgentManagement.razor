@page "/admin/agents"
@using Remittance.Web.Client.Models
@using Remittance.Web.Client.Services

<PageTitle>Agent Management - Remittance</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h5" Style="font-weight: 700;">Agent Management</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
               OnClick="@(() => _showCreatePopup = true)">
        New Agent
    </MudButton>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <MudAlert Severity="@_messageSeverity" Class="mb-4" Dense="true" ShowCloseIcon="true"
              CloseIconClicked="@(() => _message = string.Empty)">@_message</MudAlert>
}

<MudPaper Elevation="4" Class="rounded-lg">
    <MudTable Items="_agents" Hover="true" Striped="true" Dense="true" Loading="_loading"
              Filter="new Func<AgentModel, bool>(FilterFunc)">
        <ToolBarContent>
            <MudTextField @bind-Value="_searchString" Placeholder="Search agents..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Business Name</MudTh>
            <MudTh>Country</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.BusinessName</MudTd>
            <MudTd>@context.Country</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.AgentType == "SendingAgent" ? Color.Info : Color.Tertiary)">
                    @(context.AgentType == "SendingAgent" ? "Sending" : "Payout")
                </MudChip>
            </MudTd>
            <MudTd>
                <div class="d-flex align-center gap-1">
                    @if (context.Status == "Approved")
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Approved</MudChip>
                    }
                    else if (context.Status == "Blocked")
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Error">Blocked</MudChip>
                        <MudTooltip Text="Unblock">
                            <MudIconButton Icon="@Icons.Material.Filled.LockOpen" Color="Color.Success" Size="Size.Small"
                                           OnClick="@(() => UnblockAgent(context))" />
                        </MudTooltip>
                    }
                    else if (context.Status == "Rejected")
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Error">Rejected</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">Pending</MudChip>
                        <MudTooltip Text="Approve">
                            <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small"
                                           OnClick="@(() => ApproveAgent(context))" />
                        </MudTooltip>
                        <MudTooltip Text="Reject">
                            <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(() => RejectAgent(context))" />
                        </MudTooltip>
                    }
                </div>
            </MudTd>
            <MudTd>
                <MudTooltip Text="View Details">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Info"
                                   OnClick="@(() => ViewAgentDetail(context))" />
                </MudTooltip>
                @if (context.AgentType == "SendingAgent")
                {
                    <MudTooltip Text="Locations">
                        <MudIconButton Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Tertiary"
                                       OnClick="@(() => OpenLocationManagement(context))" />
                    </MudTooltip>
                }
                @if (context.AgentType == "PayoutAgent")
                {
                    <MudTooltip Text="Banks">
                        <MudIconButton Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Small" Color="Color.Primary"
                                       OnClick="@(() => OpenBankManagement(context))" />
                    </MudTooltip>
                }
                @if (context.Status == "Approved")
                {
                    <MudTooltip Text="Block">
                        <MudIconButton Icon="@Icons.Material.Filled.Block" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => BlockAgent(context))" />
                    </MudTooltip>
                }
                <MudTooltip Text="Edit">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                   OnClick="@(() => StartEditAgent(context))" />
                </MudTooltip>
                <MudTooltip Text="Delete">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => DeleteAgent(context))" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudPaper>

@* Agent Detail Popup *@
@if (_showDetail && _detailAgent != null)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 9999;" @onclick="@(() => _showDetail = false)"></div>
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 10000; width: 600px; max-width: 95vw; max-height: 90vh; overflow-y: auto;">
        <MudPaper Elevation="12" Class="pa-6 rounded-lg">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Agent Details</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => _showDetail = false)" />
            </div>
            <MudGrid>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Business Name</MudText><MudText>@_detailAgent.BusinessName</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Contact Person</MudText><MudText>@_detailAgent.FullName</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Email</MudText><MudText>@_detailAgent.Email</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Phone</MudText><MudText>@_detailAgent.PhoneNumber</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Agent Type</MudText><MudText>@(_detailAgent.AgentType == "SendingAgent" ? "Sending Agent" : "Payout Agent")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Country</MudText><MudText>@_detailAgent.Country - @_detailAgent.City</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Currency</MudText><MudText>@(_detailAgent.Currency ?? GetCurrencyForCountry(_detailAgent.Country))</MudText></MudItem>
                @if (_detailAgent.AgentType == "SendingAgent")
                {
                    <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Funding Type</MudText><MudText>@_detailAgent.FundingType</MudText></MudItem>
                    <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Credit Limit</MudText><MudText><strong>@_detailAgent.CreditLimit.ToString("N2")</strong></MudText></MudItem>
                    <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Current Balance</MudText><MudText><strong>@_detailAgent.CurrentBalance.ToString("N2")</strong></MudText></MudItem>
                }
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">License Number</MudText><MudText>@(_detailAgent.LicenseNumber ?? "-")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@(_detailAgent.Status == "Approved" ? Color.Success : _detailAgent.Status == "Blocked" ? Color.Error : Color.Warning)">@_detailAgent.Status</MudChip>
                </MudItem>
                <MudItem xs="12"><MudText Typo="Typo.caption" Color="Color.Secondary">Address</MudText><MudText>@(_detailAgent.Address ?? "-")</MudText></MudItem>
                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Created</MudText><MudText>@_detailAgent.CreatedAt.ToString("yyyy-MM-dd")</MudText></MudItem>
            </MudGrid>
        </MudPaper>
    </div>
}

@* Create Agent Popup *@
@if (_showCreatePopup)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 9999;" @onclick="@(() => _showCreatePopup = false)"></div>
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 10000; width: 750px; max-width: 95vw; max-height: 90vh; overflow-y: auto;">
        <MudPaper Elevation="12" Class="pa-6 rounded-lg">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Create New Agent</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="@(() => { _showCreatePopup = false; _newAgent = new(); })" />
            </div>
            @if (!string.IsNullOrEmpty(_createError))
            { <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_createError</MudAlert> }
            <MudCard Elevation="0" Class="mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                <MudCardContent>
                    <MudSelect T="string" @bind-Value="_newAgent.AgentType" Label="Agent Type" Variant="Variant.Outlined" Required="true">
                        <MudSelectItem Value="@("SendingAgent")">Sending Agent</MudSelectItem>
                        <MudSelectItem Value="@("PayoutAgent")">Payout Agent</MudSelectItem>
                    </MudSelect>
                </MudCardContent>
            </MudCard>
            <MudCard Elevation="0" Class="mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                <MudCardHeader><MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Company Information</MudText></MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12" sm="6"><MudTextField T="string" @bind-Value="_newAgent.BusinessName" Label="Business Name" Variant="Variant.Outlined" Required="true" RequiredError="Business name is required." /></MudItem>
                        <MudItem xs="12" sm="6"><MudTextField T="string" @bind-Value="_newAgent.LicenseNumber" Label="License Number" Variant="Variant.Outlined" /></MudItem>
                        <MudItem xs="12"><MudTextField T="string" @bind-Value="_newAgent.Address" Label="Address" Variant="Variant.Outlined" /></MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
            <MudCard Elevation="0" Class="mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                <MudCardHeader><MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Authorized Person</MudText></MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12" sm="6"><MudTextField T="string" @bind-Value="_newAgent.FullName" Label="Full Name" Variant="Variant.Outlined" Required="true" RequiredError="Full name is required." /></MudItem>
                        <MudItem xs="12" sm="6"><MudTextField T="string" @bind-Value="_newAgent.Email" Label="Email" Variant="Variant.Outlined" Required="true" RequiredError="Email is required." Validation="@(new Func<string, string?>(ValidateAgentEmail))" /></MudItem>
                        <MudItem xs="12" sm="6"><MudTextField T="string" @bind-Value="_newAgent.Phone" Label="Phone" Variant="Variant.Outlined" Required="true" RequiredError="Phone is required." /></MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
            <MudCard Elevation="0" Class="mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                <MudCardHeader><MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Accounting Details</MudText></MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="string" @bind-Value="_newAgent.Country" Label="Country" Variant="Variant.Outlined" Required="true">
                                @foreach (var c in _countries) { <MudSelectItem Value="@c.Name">@c.Name</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6"><MudTextField T="string" @bind-Value="_newAgent.City" Label="City" Variant="Variant.Outlined" Required="true" RequiredError="City is required." /></MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="string" @bind-Value="_newAgent.Currency" Label="Currency" Variant="Variant.Outlined" Required="true">
                                @foreach (var c in _currencies) { <MudSelectItem Value="@c">@c</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        @if (_newAgent.AgentType == "SendingAgent")
                        {
                            <MudItem xs="12" sm="6"><MudNumericField T="decimal" @bind-Value="_newAgent.CreditLimit" Label="Credit Limit" Variant="Variant.Outlined" Required="true" /></MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect T="string" @bind-Value="_newAgent.FundingType" Label="Funding Type" Variant="Variant.Outlined" Required="true">
                                    <MudSelectItem Value="@("PreFunding")">PreFunding</MudSelectItem>
                                    <MudSelectItem Value="@("PostFunding")">PostFunding</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                        }
                    </MudGrid>
                </MudCardContent>
            </MudCard>
            <div class="d-flex justify-end gap-2 mt-4">
                <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Close" OnClick="@(() => { _showCreatePopup = false; _newAgent = new(); })">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="CreateAgent" Disabled="_creating">
                    @if (_creating) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Create Agent
                </MudButton>
            </div>
        </MudPaper>
    </div>
}

@* Edit Agent Popup *@
@if (_showEditPopup)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 9999;" @onclick="@(() => _showEditPopup = false)"></div>
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 10000; width: 750px; max-width: 95vw; max-height: 90vh; overflow-y: auto;">
        <MudPaper Elevation="12" Class="pa-6 rounded-lg">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Edit Agent</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => _showEditPopup = false)" />
            </div>
            @if (!string.IsNullOrEmpty(_editError)) { <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_editError</MudAlert> }
            <MudCard Elevation="0" Class="mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                <MudCardHeader><MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Company Information</MudText></MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12" sm="6"><MudTextField T="string" @bind-Value="_editAgent.BusinessName" Label="Business Name" Variant="Variant.Outlined" Required="true" /></MudItem>
                        <MudItem xs="12" sm="6"><MudTextField T="string" @bind-Value="_editAgent.LicenseNumber" Label="License Number" Variant="Variant.Outlined" /></MudItem>
                        <MudItem xs="12"><MudTextField T="string" @bind-Value="_editAgent.Address" Label="Address" Variant="Variant.Outlined" /></MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
            <MudCard Elevation="0" Class="mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                <MudCardHeader><MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Authorized Person</MudText></MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12" sm="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Full Name</MudText><MudText Typo="Typo.body1">@_editAgentFullName</MudText></MudItem>
                        <MudItem xs="12" sm="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Email</MudText><MudText Typo="Typo.body1">@_editAgentEmail</MudText></MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
            <MudCard Elevation="0" Class="mb-4" Style="border: 1px solid var(--mud-palette-lines-default);">
                <MudCardHeader><MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Accounting Details</MudText></MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="string" @bind-Value="_editAgent.Country" Label="Country" Variant="Variant.Outlined" Required="true">
                                @foreach (var c in _countries) { <MudSelectItem Value="@c.Name">@c.Name</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6"><MudTextField T="string" @bind-Value="_editAgent.City" Label="City" Variant="Variant.Outlined" Required="true" /></MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="string" @bind-Value="_editAgent.Currency" Label="Currency" Variant="Variant.Outlined" Required="true">
                                @foreach (var c in _currencies) { <MudSelectItem Value="@c">@c</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        @if (_editAgent.AgentType == "SendingAgent")
                        {
                            <MudItem xs="12" sm="6"><MudNumericField T="decimal" @bind-Value="_editAgent.CreditLimit" Label="Credit Limit" Variant="Variant.Outlined" Required="true" /></MudItem>
                            <MudItem xs="12" sm="6">
                                <MudSelect T="string" @bind-Value="_editAgent.FundingType" Label="Funding Type" Variant="Variant.Outlined" Required="true">
                                    <MudSelectItem Value="@("PreFunding")">PreFunding</MudSelectItem>
                                    <MudSelectItem Value="@("PostFunding")">PostFunding</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                        }
                        <MudItem xs="12" sm="6">
                            <MudSelect T="string" @bind-Value="_editAgent.AgentType" Label="Agent Type" Variant="Variant.Outlined" Required="true">
                                <MudSelectItem Value="@("SendingAgent")">Sending Agent</MudSelectItem>
                                <MudSelectItem Value="@("PayoutAgent")">Payout Agent</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
            <div class="d-flex justify-end gap-2 mt-4">
                <MudButton StartIcon="@Icons.Material.Filled.Close" OnClick="@(() => _showEditPopup = false)">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="UpdateAgent" Disabled="_updating">
                    @if (_updating) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Save Changes
                </MudButton>
            </div>
        </MudPaper>
    </div>
}

@* ---- Location Management Popup (Sending Agents) ---- *@
@if (_showLocationPopup)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 9999;" @onclick="@(() => _showLocationPopup = false)"></div>
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 10000; width: 900px; max-width: 95vw; max-height: 85vh; overflow-y: auto;">
        <MudPaper Elevation="12" Class="pa-6 rounded-lg">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6" Style="font-weight: 600;"><MudIcon Icon="@Icons.Material.Filled.LocationOn" Class="mr-1" /> Locations — @_locationAgent?.BusinessName</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => _showLocationPopup = false)" />
            </div>
            @if (!string.IsNullOrEmpty(_locationMessage))
            { <MudAlert Severity="@_locationSeverity" Class="mb-3" Dense="true" ShowCloseIcon="true" CloseIconClicked="@(() => _locationMessage = string.Empty)">@_locationMessage</MudAlert> }
            <div class="d-flex justify-end mb-3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => OpenLocationForm(null))">Add Location</MudButton>
            </div>
            @if (_agentLocations.Any())
            {
                <MudTable Items="_agentLocations" Hover="true" Dense="true" Striped="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>Location</MudTh><MudTh>Code</MudTh><MudTh>Country / City</MudTh><MudTh>Users</MudTh><MudTh>Status</MudTh><MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.LocationName</MudTd>
                        <MudTd>@(context.LocationCode ?? "-")</MudTd>
                        <MudTd>@(context.Country ?? "-") / @(context.City ?? "-")</MudTd>
                        <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Primary">@context.Users.Count</MudChip></MudTd>
                        <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">@(context.IsActive ? "Active" : "Inactive")</MudChip></MudTd>
                        <MudTd>
                            <MudTooltip Text="Manage Users"><MudIconButton Icon="@Icons.Material.Filled.People" Size="Size.Small" Color="Color.Primary" OnClick="@(() => OpenUserManagement(context))" /></MudTooltip>
                            <MudTooltip Text="Edit"><MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Warning" OnClick="@(() => OpenLocationForm(context))" /></MudTooltip>
                            <MudTooltip Text="@(context.IsActive ? "Deactivate" : "Activate")"><MudIconButton Icon="@(context.IsActive ? Icons.Material.Filled.ToggleOn : Icons.Material.Filled.ToggleOff)" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)" OnClick="@(() => ToggleLocation(context.Id))" /></MudTooltip>
                            <MudTooltip Text="Delete"><MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteLocation(context.Id))" /></MudTooltip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else { <MudAlert Severity="Severity.Info" Dense="true">No locations configured yet.</MudAlert> }
        </MudPaper>
    </div>
}

@* Location Add/Edit Form *@
@if (_showLocationForm)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 10001;" @onclick="@(() => _showLocationForm = false)"></div>
    <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 10002; width: 550px; max-width: 95vw; max-height: 85vh; overflow-y: auto;">
        <MudPaper Elevation="12" Class="pa-6 rounded-lg">
            <MudText Typo="Typo.h6" Class="mb-4">@(_editingLocationId.HasValue ? "Edit Location" : "Add New Location")</MudText>
            @if (!string.IsNullOrEmpty(_locationFormError)) { <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true">@_locationFormError</MudAlert> }
            <MudTextField @bind-Value="_locName" Label="Location Name *" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_locCode" Label="Location Code" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_locCountry" Label="Country" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_locCity" Label="City" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_locAddress" Label="Address" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_locPhone" Label="Contact Phone" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_locEmail" Label="Contact Email" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_locHours" Label="Operating Hours" Variant="Variant.Outlined" Placeholder="e.g. Mon-Fri 9AM-5PM" Class="mb-4" />
            <div class="d-flex justify-end gap-2">
