@code {
    private List<AgentModel> _agents = new();
    private string _searchString = string.Empty;
    private bool _loading = true;
    private bool _showCreatePopup, _creating;
    private string _message = string.Empty;
    private Severity _messageSeverity = Severity.Info;
    private CreateAgentForm _newAgent = new();
    private string _createError = string.Empty;
    private bool _showEditPopup, _updating;
    private int _editAgentId;
    private string _editError = string.Empty;
    private EditAgentForm _editAgent = new();
    private string _editAgentFullName = string.Empty, _editAgentEmail = string.Empty;
    private bool _showDetail;
    private AgentModel? _detailAgent;

    // Location management
    private bool _showLocationPopup, _showLocationForm;
    private AgentModel? _locationAgent;
    private List<AgentLocationModel> _agentLocations = new();
    private List<PaymentMethodModel> _paymentMethods = new();
    private string _locationMessage = string.Empty, _locationFormError = string.Empty;
    private Severity _locationSeverity = Severity.Info;
    private int? _editingLocationId;
    private string _locName = string.Empty;
    private string? _locCode, _locCountry, _locCity, _locAddress, _locPhone, _locEmail, _locHours;

    // User management (AgentLocationUser)
    private bool _showUserPopup, _showUserForm;
    private AgentLocationModel? _userLocation;
    private string _userMessage = string.Empty, _userFormError = string.Empty;
    private Severity _userSeverity = Severity.Info;
    private int? _editingUserId;
    private string _userFullName = string.Empty, _userEmail = string.Empty;
    private string? _userUserName, _userPassword, _userPhone;
    private string _userRole = "Operator";
    private bool _userIsDefault;

    // Bank management (AgentBank)
    private bool _showBankPopup, _showBankForm;
    private AgentModel? _bankAgent;
    private List<AgentBankModel> _agentBanks = new();
    private string _bankMessage = string.Empty, _bankFormError = string.Empty;
    private Severity _bankSeverity = Severity.Info;
    private int? _editingBankId;
    private string _bankName = string.Empty;
    private string? _bankCode, _bankSwift, _bankRouting, _bankCountry, _bankCity, _bankAddress, _bankPhone, _bankEmail, _bankAdditionalInfo;

    // Bank Branch management (AgentBankBranch)
    private bool _showBankBranchPopup, _showBankBranchForm;
    private AgentBankModel? _bankBranchBank;
    private string _bankBranchMessage = string.Empty, _bankBranchFormError = string.Empty;
    private Severity _bankBranchSeverity = Severity.Info;
    private int? _editingBankBranchId;
    private string _bbName = string.Empty;
    private string? _bbCode, _bbSwift, _bbAddress, _bbPhone;

    [Inject] private ApiService Api { get; set; } = null!;
    [Inject] private AuthStateService Auth { get; set; } = null!;
    private List<CountryInfo> _countries = new();
    private List<string> _currencies = new();

    private string GetCurrencyForCountry(string country) =>
        _countries.FirstOrDefault(c => c.Name.Equals(country, StringComparison.OrdinalIgnoreCase))?.Currency ?? "USD";

    private Task<IEnumerable<string>> SearchCountries(string value, CancellationToken token)
        => Task.FromResult(string.IsNullOrEmpty(value)
            ? _countries.Select(c => c.Name)
            : _countries.Where(c => c.Name.Contains(value, StringComparison.OrdinalIgnoreCase)).Select(c => c.Name));

    private Task<IEnumerable<string>> SearchCurrencies(string value, CancellationToken token)
        => Task.FromResult(string.IsNullOrEmpty(value)
            ? _currencies.AsEnumerable()
            : _currencies.Where(c => c.Contains(value, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        await Auth.LoadFromSessionAsync();
        await Task.WhenAll(LoadReferenceData(), LoadAgents());
    }

    private async Task LoadReferenceData()
    {
        try
        {
            var cr = await Api.GetCountriesAsync();
            var cu = await Api.GetCurrenciesAsync();
            if (cr?.Success == true && cr.Data != null) _countries = cr.Data;
            if (cu?.Success == true && cu.Data != null) _currencies = cu.Data;
        }
        catch { }
    }

    private async Task LoadAgents()
    {
        _loading = true;
        try
        {
            var result = await Api.GetAgentsAsync();
            if (result?.Success == true && result.Data != null) _agents = result.Data;
            else { _agents = new(); _message = result?.Message ?? "Failed to load agents."; _messageSeverity = Severity.Error; }
        }
        catch (Exception ex) { _agents = new(); _message = $"Could not connect: {ex.Message}"; _messageSeverity = Severity.Error; }
        finally { _loading = false; }
    }

    private void ViewAgentDetail(AgentModel agent) { _detailAgent = agent; _showDetail = true; }

    private async Task ApproveAgent(AgentModel agent)
    {
        try { var r = await Api.ApproveAgentAsync(agent.Id); if (r?.Success == true) { agent.Status = "Approved"; agent.IsApproved = true; _message = $"Agent '{agent.BusinessName}' approved."; _messageSeverity = Severity.Success; } else { _message = r?.Message ?? "Failed."; _messageSeverity = Severity.Error; } }
        catch (Exception ex) { _message = $"Error: {ex.Message}"; _messageSeverity = Severity.Error; }
        StateHasChanged();
    }

    private async Task RejectAgent(AgentModel agent)
    {
        try { var r = await Api.RejectAgentAsync(agent.Id); if (r?.Success == true) { agent.Status = "Rejected"; agent.IsApproved = false; agent.IsActive = false; _message = $"Agent '{agent.BusinessName}' rejected."; _messageSeverity = Severity.Warning; } else { _message = r?.Message ?? "Failed."; _messageSeverity = Severity.Error; } }
        catch (Exception ex) { _message = $"Error: {ex.Message}"; _messageSeverity = Severity.Error; }
        StateHasChanged();
    }

    private async Task BlockAgent(AgentModel agent)
    {
        try { var r = await Api.BlockAgentAsync(agent.Id); if (r?.Success == true) { agent.Status = "Blocked"; agent.IsActive = false; _message = $"Agent '{agent.BusinessName}' blocked."; _messageSeverity = Severity.Warning; } else { _message = r?.Message ?? "Failed."; _messageSeverity = Severity.Error; } }
        catch (Exception ex) { _message = $"Error: {ex.Message}"; _messageSeverity = Severity.Error; }
        StateHasChanged();
    }

    private async Task UnblockAgent(AgentModel agent)
    {
        try { var r = await Api.UnblockAgentAsync(agent.Id); if (r?.Success == true) { agent.Status = "Approved"; agent.IsActive = true; _message = $"Agent '{agent.BusinessName}' unblocked."; _messageSeverity = Severity.Success; } else { _message = r?.Message ?? "Failed."; _messageSeverity = Severity.Error; } }
        catch (Exception ex) { _message = $"Error: {ex.Message}"; _messageSeverity = Severity.Error; }
        StateHasChanged();
    }

    private string? ValidateAgentEmail(string email)
    {
        if (string.IsNullOrWhiteSpace(email)) return "Email is required.";
        if (!email.Contains('@') || !email.Contains('.')) return "Invalid email format.";
        return null;
    }

    private async Task CreateAgent()
    {
        _creating = true; _createError = string.Empty;
        var isSending = _newAgent.AgentType == "SendingAgent";
        if (string.IsNullOrWhiteSpace(_newAgent.FullName) || string.IsNullOrWhiteSpace(_newAgent.Email) || string.IsNullOrWhiteSpace(_newAgent.Phone) || string.IsNullOrWhiteSpace(_newAgent.BusinessName) || string.IsNullOrWhiteSpace(_newAgent.Country) || string.IsNullOrWhiteSpace(_newAgent.City))
        { _createError = "Please fill in all required fields."; _creating = false; return; }
        if (isSending && _newAgent.CreditLimit <= 0) { _createError = "Credit limit must be greater than zero."; _creating = false; return; }
        try
        {
            var dto = new { fullName = _newAgent.FullName, email = _newAgent.Email, phoneNumber = _newAgent.Phone, businessName = _newAgent.BusinessName, agentType = _newAgent.AgentType, country = _newAgent.Country, city = _newAgent.City, creditLimit = isSending ? _newAgent.CreditLimit : 0m, licenseNumber = _newAgent.LicenseNumber, address = _newAgent.Address, currency = _newAgent.Currency, fundingType = isSending ? _newAgent.FundingType : (string?)null };
            var result = await Api.CreateAgentAsync(dto);
            if (result?.Success == true) { _message = "Agent created!"; _messageSeverity = Severity.Success; _newAgent = new(); _showCreatePopup = false; await LoadAgents(); }
            else { _createError = result?.Message ?? "Failed."; }
        }
        catch (Exception ex) { _message = $"Error: {ex.Message}"; _messageSeverity = Severity.Error; }
        finally { _creating = false; }
    }

    private void StartEditAgent(AgentModel agent)
    {
        _editAgentId = agent.Id; _editAgentFullName = agent.FullName; _editAgentEmail = agent.Email;
        _editAgent = new EditAgentForm { BusinessName = agent.BusinessName, AgentType = agent.AgentType, Country = agent.Country, City = agent.City, CreditLimit = agent.CreditLimit, LicenseNumber = agent.LicenseNumber ?? "", Address = agent.Address ?? "", Currency = agent.Currency ?? GetCurrencyForCountry(agent.Country), FundingType = agent.FundingType ?? "PreFunding" };
        _editError = string.Empty; _showEditPopup = true;
    }

    private async Task UpdateAgent()
    {
        _editError = string.Empty;
        if (string.IsNullOrWhiteSpace(_editAgent.BusinessName) || string.IsNullOrWhiteSpace(_editAgent.Country)) { _editError = "Please fill in all required fields."; return; }
        if (_editAgent.AgentType == "SendingAgent" && _editAgent.CreditLimit <= 0) { _editError = "Credit limit must be greater than zero."; return; }
        _updating = true;
        try
        {
            var dto = new { businessName = _editAgent.BusinessName, country = _editAgent.Country, city = _editAgent.City, agentType = _editAgent.AgentType, creditLimit = _editAgent.CreditLimit, licenseNumber = _editAgent.LicenseNumber, address = _editAgent.Address, currency = _editAgent.Currency, fundingType = _editAgent.FundingType };
            var result = await Api.UpdateAgentAsync(_editAgentId, dto);
            if (result?.Success == true) { _message = $"Agent '{_editAgent.BusinessName}' updated."; _messageSeverity = Severity.Success; _showEditPopup = false; await LoadAgents(); }
            else { _editError = result?.Message ?? "Failed."; }
        }
        catch (Exception ex) { _editError = $"Error: {ex.Message}"; }
        finally { _updating = false; }
    }

    private async Task DeleteAgent(AgentModel agent)
    {
        try { var r = await Api.DeleteAgentAsync(agent.Id); if (r?.Success == true) { _message = $"Agent '{agent.BusinessName}' deleted."; _messageSeverity = Severity.Success; await LoadAgents(); } else { _message = r?.Message ?? "Failed."; _messageSeverity = Severity.Error; } }
        catch (Exception ex) { _message = $"Error: {ex.Message}"; _messageSeverity = Severity.Error; }
    }

    private bool FilterFunc(AgentModel agent) => string.IsNullOrWhiteSpace(_searchString) || agent.BusinessName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) || agent.FullName.Contains(_searchString, StringComparison.OrdinalIgnoreCase);

