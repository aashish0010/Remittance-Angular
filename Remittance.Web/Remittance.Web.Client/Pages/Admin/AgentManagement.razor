    // ---- Location Management ----
    private async Task OpenLocationManagement(AgentModel agent) { _locationAgent = agent; _locationMessage = ""; await LoadPaymentMethods(); await LoadAgentLocations(agent.Id); _showLocationPopup = true; }
    private async Task LoadPaymentMethods() { if (!_paymentMethods.Any()) { var r = await Api.GetPaymentMethodsAsync(); if (r?.Success == true) _paymentMethods = r.Data ?? new(); } }
    private async Task LoadAgentLocations(int agentId) { var r = await Api.GetAgentLocationsAsync(agentId); if (r?.Success == true) _agentLocations = r.Data ?? new(); }

    private void OpenLocationForm(AgentLocationModel? existing)
    {
        _locationFormError = "";
        if (existing != null) { _editingLocationId = existing.Id; _locName = existing.LocationName; _locCode = existing.LocationCode; _locCountry = existing.Country; _locCity = existing.City; _locAddress = existing.Address; _locPhone = existing.ContactPhone; _locEmail = existing.ContactEmail; _locHours = existing.OperatingHours; }
        else { _editingLocationId = null; _locName = ""; _locCode = null; _locCountry = _locationAgent?.Country; _locCity = null; _locAddress = null; _locPhone = null; _locEmail = null; _locHours = null; }
        _showLocationForm = true;
    }

    private async Task SaveLocation()
    {
        _locationFormError = ""; if (string.IsNullOrWhiteSpace(_locName)) { _locationFormError = "Location name is required."; return; }
        var pmId = _paymentMethods.FirstOrDefault()?.Id ?? 1;
        var payload = new { agentId = _locationAgent?.Id, paymentMethodId = pmId, locationName = _locName, locationCode = _locCode, country = _locCountry, city = _locCity, address = _locAddress, contactPhone = _locPhone, contactEmail = _locEmail, operatingHours = _locHours };
        if (_editingLocationId.HasValue)
        { var r = await Api.UpdateAgentLocationAsync(_editingLocationId.Value, payload); if (r?.Success == true) { _locationMessage = "Location updated."; _locationSeverity = Severity.Success; _showLocationForm = false; if (_locationAgent != null) await LoadAgentLocations(_locationAgent.Id); } else { _locationFormError = r?.Message ?? "Failed."; } }
        else
        { var r = await Api.CreateAgentLocationAsync(payload); if (r?.Success == true) { _locationMessage = "Location added."; _locationSeverity = Severity.Success; _showLocationForm = false; if (_locationAgent != null) await LoadAgentLocations(_locationAgent.Id); } else { _locationFormError = r?.Message ?? "Failed."; } }
    }

    private async Task ToggleLocation(int id) { var r = await Api.ToggleAgentLocationAsync(id); if (r?.Success == true) { _locationMessage = r.Message; _locationSeverity = Severity.Success; if (_locationAgent != null) await LoadAgentLocations(_locationAgent.Id); } else { _locationMessage = r?.Message ?? "Failed."; _locationSeverity = Severity.Error; } }
    private async Task DeleteLocation(int id) { var r = await Api.DeleteAgentLocationAsync(id); if (r?.Success == true) { _locationMessage = "Deleted."; _locationSeverity = Severity.Success; if (_locationAgent != null) await LoadAgentLocations(_locationAgent.Id); } else { _locationMessage = r?.Message ?? "Failed."; _locationSeverity = Severity.Error; } }

    // ---- User Management (AgentLocationUser API) ----
    private void OpenUserManagement(AgentLocationModel loc) { _userLocation = loc; _userMessage = ""; _showUserPopup = true; }

    private void OpenUserForm(AgentLocationUserModel? existing)
    {
        _userFormError = "";
        if (existing != null) { _editingUserId = existing.Id; _userFullName = existing.FullName; _userEmail = existing.Email; _userUserName = existing.UserName; _userPassword = null; _userPhone = existing.Phone; _userRole = existing.Role ?? "Operator"; _userIsDefault = existing.IsDefault; }
        else { _editingUserId = null; _userFullName = ""; _userEmail = ""; _userUserName = null; _userPassword = null; _userPhone = null; _userRole = "Operator"; _userIsDefault = false; }
        _showUserForm = true;
    }

    private async Task SaveUser()
    {
        _userFormError = "";
        if (string.IsNullOrWhiteSpace(_userFullName)) { _userFormError = "Full name is required."; return; }
        if (string.IsNullOrWhiteSpace(_userEmail)) { _userFormError = "Email is required."; return; }
        if (!_editingUserId.HasValue && string.IsNullOrWhiteSpace(_userPassword)) { _userFormError = "Password is required."; return; }
        if (_editingUserId.HasValue)
        {
            var dto = new UpdateLocationUserRequest
            {
                FullName = _userFullName,
                Email = _userEmail,
                UserName = _userUserName,
                Password = _userPassword,
                Phone = _userPhone,
                Role = _userRole,
                IsDefault = _userIsDefault
            };
            var r = await Api.UpdateLocationUserAsync(_editingUserId.Value, dto);
            if (r?.Success == true) { _userMessage = "User updated."; _userSeverity = Severity.Success; _showUserForm = false; await RefreshUserLocation(); }
            else { _userFormError = r?.Message ?? "Failed."; }
        }
        else
        {
            var dto = new CreateLocationUserRequest
            {
                AgentLocationId = _userLocation?.Id ?? 0,
                FullName = _userFullName,
                Email = _userEmail,
                UserName = _userUserName,
                Password = _userPassword,
                Phone = _userPhone,
                Role = _userRole,
                IsDefault = _userIsDefault
            };
            var r = await Api.CreateLocationUserAsync(dto);
            if (r?.Success == true) { _userMessage = "User added."; _userSeverity = Severity.Success; _showUserForm = false; await RefreshUserLocation(); }
            else { _userFormError = r?.Message ?? "Failed."; }
        }
    }

    private async Task DeleteUser(int id) { var r = await Api.DeleteLocationUserAsync(id); if (r?.Success == true) { _userMessage = "User deleted."; _userSeverity = Severity.Success; await RefreshUserLocation(); } else { _userMessage = r?.Message ?? "Failed."; _userSeverity = Severity.Error; } }

    private async Task RefreshUserLocation()
    {
        if (_locationAgent == null) return;
        await LoadAgentLocations(_locationAgent.Id);
        if (_userLocation != null) _userLocation = _agentLocations.FirstOrDefault(l => l.Id == _userLocation.Id);
    }

