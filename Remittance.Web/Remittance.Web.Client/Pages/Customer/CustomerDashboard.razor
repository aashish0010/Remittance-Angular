@page "/customer/dashboard"
@using Remittance.Web.Client.Models
@using Remittance.Web.Client.Services

<PageTitle>Customer Dashboard - Remittance</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 700;">Welcome Back!</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}

<MudGrid>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total Transactions</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;">@_transactions.Count</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Lifetime</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Large" Color="Color.Primary" />
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total Sent</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;">$@_totalSent.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">All time</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Large" Color="Color.Info" />
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">KYC Status</MudText>
                    <MudText Typo="Typo.h5" Style="font-weight: 700;" Color="Color.Success">Verified</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Large" Color="Color.Success" />
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudGrid Class="mt-4">
    <MudItem xs="12" md="6">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg">
            <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 600;">Quick Rate Check</MudText>
            <MudGrid>
                <MudItem xs="5">
                    <MudSelect T="string" Value="_fromCurrency" Label="From" Variant="Variant.Outlined"
                               Dense="true" ValueChanged="@OnFromCurrencyChanged">
                        @foreach (var c in _currencies) { <MudSelectItem Value="@c">@c</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="2" Class="d-flex align-center justify-center">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Color="Color.Primary" />
                </MudItem>
                <MudItem xs="5">
                    <MudSelect T="string" Value="_toCurrency" Label="To" Variant="Variant.Outlined"
                               Dense="true" ValueChanged="@OnToCurrencyChanged">
                        @foreach (var c in _currencies) { <MudSelectItem Value="@c">@c</MudSelectItem> }
                    </MudSelect>
                </MudItem>
            </MudGrid>
            @if (_loadingRate)
            {
                <MudProgressLinear Indeterminate="true" Size="Size.Small" Class="mt-3" />
            }
            else
            {
                <MudText Typo="Typo.h5" Class="text-center mt-4" Style="font-weight: 700;" Color="Color.Primary">
                    1 @_fromCurrency = @_rate.ToString("N4") @_toCurrency
                </MudText>
            }
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-4"
                       Href="/customer/send" StartIcon="@Icons.Material.Filled.Send">
                Send Money
            </MudButton>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg">
            <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 600;">Recent Transfers</MudText>
            @if (_transactions.Any())
            {
                <MudList T="string" Dense="true">
                    @foreach (var tx in _transactions.Take(4))
                    {
                        <MudListItem>
                            <div class="d-flex justify-space-between align-center">
                                <div>
                                    <MudText Typo="Typo.body1"><strong>@tx.ReceiverName</strong></MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@tx.ReceiverCountry — @tx.CreatedAt.ToString("MMM dd, yyyy")</MudText>
                                </div>
                                <div class="text-right">
                                    <MudText Typo="Typo.body2" Style="font-weight: 600;">@tx.SendAmount.ToString("N2") @tx.SendCurrency</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(tx.Status)">@tx.Status</MudChip>
                                </div>
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No transactions yet.</MudText>
            }
            <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Class="mt-2"
                       StartIcon="@Icons.Material.Filled.List" Href="/customer/transactions">
                View All Transactions
            </MudButton>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private string _fromCurrency = "USD";
    private string _toCurrency = "NPR";
    private decimal _rate;
    private bool _loading = true;
    private bool _loadingRate;
    private decimal _totalSent;
    private List<string> _currencies = new();
    private List<TransactionResult> _transactions = new();

    [Inject] private ApiService Api { get; set; } = null!;
    [Inject] private AuthStateService Auth { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        await Auth.LoadFromSessionAsync();
        await Task.WhenAll(LoadCurrencies(), LoadTransactions());
        await FetchRate();
        _loading = false;
    }

    private async Task LoadCurrencies()
    {
        try
        {
            var cu = await Api.GetCurrenciesAsync();
            if (cu?.Success == true && cu.Data != null)
                _currencies = cu.Data;
        }
        catch { }
    }

    private async Task LoadTransactions()
    {
        try
        {
            var result = await Api.GetCustomerTransactionsAsync();
            if (result?.Success == true && result.Data != null)
            {
                _transactions = result.Data;
                _totalSent = _transactions.Where(t => t.Status == "Completed").Sum(t => t.SendAmount);
            }
        }
        catch { }
    }

    private async Task FetchRate()
    {
        if (string.IsNullOrEmpty(_fromCurrency) || string.IsNullOrEmpty(_toCurrency)) return;
        _loadingRate = true;
        try
        {
            var result = await Api.GetCurrentRateAsync(_fromCurrency, _toCurrency);
            _rate = result?.Success == true && result.Data != null ? result.Data.Rate : 0;
        }
        catch { _rate = 0; }
        _loadingRate = false;
    }

    private async void OnFromCurrencyChanged(string val) { _fromCurrency = val; await FetchRate(); }
    private async void OnToCurrencyChanged(string val) { _toCurrency = val; await FetchRate(); }

    private Task<IEnumerable<string>> SearchCurrencies(string value, CancellationToken token)
        => Task.FromResult(string.IsNullOrEmpty(value)
            ? _currencies.AsEnumerable()
            : _currencies.Where(c => c.Contains(value, StringComparison.OrdinalIgnoreCase)));

    private static Color GetStatusColor(string status) => status switch
    {
        "Completed" => Color.Success,
        "Pending" => Color.Warning,
        "Approved" or "Processing" => Color.Info,
        "Cancelled" or "Failed" => Color.Error,
        _ => Color.Default
    };
}
