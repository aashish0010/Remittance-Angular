@page "/customer/send"
@using Remittance.Web.Client.Models
@using Remittance.Web.Client.Services

<PageTitle>Send Money - Customer Portal</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 700;">Send Money Online</MudText>

@if (!string.IsNullOrEmpty(_error))
{
    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true" ShowCloseIcon="true"
              CloseIconClicked="@(() => _error = string.Empty)">@_error</MudAlert>
}

<MudGrid>
    <MudItem xs="12" md="7">
        <MudPaper Elevation="4" Class="pa-6 rounded-lg">
            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.h6" Class="mb-2" Style="font-weight: 600;">Receiver Details</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.ReceiverName" Label="Receiver Full Name"
                                  Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.ReceiverPhone" Label="Receiver Phone"
                                  Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="_model.ReceiverCountry" Label="Destination Country"
                               Variant="Variant.Outlined" Dense="true">
                        @foreach (var c in _countries) { <MudSelectItem Value="@c">@c</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.ReceiverBankName" Label="Bank Name"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.ReceiverAccountNumber" Label="Account Number"
                                  Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.h6" Class="mb-2 mt-2" Style="font-weight: 600;">Transfer Details</MudText>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField T="decimal" Value="_model.SendAmount" Label="Amount" Variant="Variant.Outlined"
                                     Adornment="Adornment.Start" AdornmentText="$" Format="N2"
                                     Immediate="true" ValueChanged="OnAmountChanged" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="int" @bind-Value="_model.PaymentMethod" Label="Payment Method"
                               Variant="Variant.Outlined">
                        <MudSelectItem Value="2">Credit/Debit Card</MudSelectItem>
                        <MudSelectItem Value="1">Bank Transfer</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="int" @bind-Value="_model.PayoutMethod" Label="Payout Method"
                               Variant="Variant.Outlined">
                        <MudSelectItem Value="1">Bank Deposit</MudSelectItem>
                        <MudSelectItem Value="0">Cash Pickup</MudSelectItem>
                        <MudSelectItem Value="4">Mobile Wallet</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Purpose" Label="Purpose of Transfer" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-4"
                       Size="Size.Large" OnClick="SubmitTransfer" Disabled="_submitting"
                       StartIcon="@Icons.Material.Filled.Send">
                @if (_submitting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Send Transfer
            </MudButton>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="5">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg" Style="position: sticky; top: 80px;">
            <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 600;">Transfer Summary</MudText>

            <div class="mb-3">
                <MudText Typo="Typo.body2" Color="Color.Secondary">You Send</MudText>
                <MudText Typo="Typo.h5" Style="font-weight: 700;">@_model.SendAmount.ToString("N2") USD</MudText>
            </div>

            <div class="mb-3">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Exchange Rate</MudText>
                @if (_loadingRate)
                {
                    <MudProgressLinear Indeterminate="true" Size="Size.Small" />
                }
                else
                {
                    <MudText Typo="Typo.body1" Style="font-weight: 600;">1 USD = @_exchangeRate.ToString("N4") NPR</MudText>
                }
            </div>

            <div class="mb-3">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Transfer Fee</MudText>
                <MudText Typo="Typo.body1" Style="font-weight: 600;">@_fee.ToString("C")</MudText>
            </div>

            <MudDivider Class="my-3" />

            <div class="mb-3">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Receiver Gets</MudText>
                <MudText Typo="Typo.h4" Style="font-weight: 700;" Color="Color.Success">
                    @_receiveAmount.ToString("N2") NPR
                </MudText>
            </div>

            <div>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Total You Pay</MudText>
                <MudText Typo="Typo.h6" Style="font-weight: 700;">
                    @((_model.SendAmount + _fee).ToString("C"))
                </MudText>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private SendTransactionModel _model = new() { SendCurrency = "USD", ReceiveCurrency = "NPR", ReceiverCountry = "Nepal" };
    private bool _submitting;
    private bool _loadingRate;
    private decimal _receiveAmount;
    private decimal _fee;
    private decimal _exchangeRate;
    private string _error = string.Empty;
    private List<string> _countries = new();

    [Inject] private ISnackbar Snackbar { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;
    [Inject] private ApiService Api { get; set; } = null!;
    [Inject] private AuthStateService Auth { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        await Auth.LoadFromSessionAsync();
        try
        {
            var cr = await Api.GetCountriesAsync();
            if (cr?.Success == true && cr.Data != null)
                _countries = cr.Data.Select(c => c.Name).ToList();
        }
        catch { }
        await FetchRate();
    }

    private async Task FetchRate()
    {
        _loadingRate = true;
        try
        {
            var result = await Api.GetCurrentRateAsync(_model.SendCurrency, _model.ReceiveCurrency);
            _exchangeRate = result?.Success == true && result.Data != null ? result.Data.Rate : 133.50m;
        }
        catch { _exchangeRate = 133.50m; }
        _loadingRate = false;
        RecalcSummary();
    }

    private Task<IEnumerable<string>> SearchCountries(string value, CancellationToken token)
        => Task.FromResult(string.IsNullOrEmpty(value)
            ? _countries.AsEnumerable()
            : _countries.Where(c => c.Contains(value, StringComparison.OrdinalIgnoreCase)));

    private void OnAmountChanged(decimal amount)
    {
        _model.SendAmount = amount;
        RecalcSummary();
    }

    private void RecalcSummary()
    {
        _receiveAmount = Math.Round(_model.SendAmount * _exchangeRate, 2);
        _fee = _model.SendAmount <= 500
            ? Math.Round(_model.SendAmount * 0.03m + 5, 2)
            : Math.Round(_model.SendAmount * 0.025m + 3, 2);
    }

    private async Task SubmitTransfer()
    {
        if (string.IsNullOrWhiteSpace(_model.ReceiverName)) { _error = "Receiver name is required."; return; }
        if (string.IsNullOrWhiteSpace(_model.ReceiverPhone)) { _error = "Receiver phone is required."; return; }
        if (_model.SendAmount <= 0) { _error = "Amount must be greater than zero."; return; }

        _submitting = true;
        _error = string.Empty;
        try
        {
            var result = await Api.SendTransactionAsync(_model);
            if (result?.Success == true)
            {
                Snackbar.Add($"Transfer submitted! Ref: {result.Data?.ReferenceNumber}", Severity.Success);
                Navigation.NavigateTo("/customer/transactions");
            }
            else
            {
                _error = result?.Message ?? "Failed to submit transfer.";
            }
        }
        catch (Exception ex) { _error = $"Error: {ex.Message}"; }
        finally { _submitting = false; }
    }
}
