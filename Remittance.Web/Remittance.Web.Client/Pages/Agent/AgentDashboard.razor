@page "/agent/dashboard"
@using Remittance.Web.Client.Models
@using Remittance.Web.Client.Services

<PageTitle>Agent Dashboard - Remittance</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 700;">Agent Dashboard</MudText>

@if (!string.IsNullOrEmpty(_error))
{
    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_error</MudAlert>
}

<MudGrid>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Credit Limit</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;">@_balance.CreditLimit.ToString("N2")</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Large" Color="Color.Primary" />
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Used Balance</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;">@_balance.CurrentBalance.ToString("N2")</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Size="Size.Large" Color="Color.Warning" />
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Available</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;" Color="Color.Success">@_balance.AvailableBalance.ToString("N2")</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.Wallet" Size="Size.Large" Color="Color.Success" />
            </div>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total Transactions</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700;">@_transactions.Count</MudText>
                </div>
                <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Size="Size.Large" Color="Color.Info" />
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudGrid Class="mt-4">
    <MudItem xs="12" md="4">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg">
            <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 600;">@_balance.BusinessName</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-4"
                       Href="/agent/send" StartIcon="@Icons.Material.Filled.Send">
                Send Money Now
            </MudButton>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="8">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg">
            <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 600;">Recent Transactions</MudText>
            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            else if (_transactions.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No transactions yet.</MudText>
            }
            else
            {
                <MudSimpleTable Hover="true" Dense="true" Striped="true">
                    <thead>
                        <tr>
                            <th>Reference</th>
                            <th>Receiver</th>
                            <th>Amount</th>
                            <th>Commission</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tx in _transactions.Take(5))
                        {
                            <tr>
                                <td style="font-family: monospace;">@tx.ReferenceNumber</td>
                                <td>@tx.ReceiverName (@tx.ReceiverCountry)</td>
                                <td>@tx.SendAmount.ToString("N2") @tx.SendCurrency → @tx.ReceiveAmount.ToString("N2") @tx.ReceiveCurrency</td>
                                <td>@tx.AgentCommission.ToString("C")</td>
                                <td><MudChip T="string" Size="Size.Small" Color="@GetStatusColor(tx.Status)">@tx.Status</MudChip></td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private AgentBalance _balance = new();
    private List<TransactionResult> _transactions = new();
    private bool _loading = true;
    private string _error = string.Empty;

    [Inject] private ApiService Api { get; set; } = null!;
    [Inject] private AuthStateService Auth { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        await Auth.LoadFromSessionAsync();
        await Task.WhenAll(LoadBalance(), LoadTransactions());
        _loading = false;
    }

    private async Task LoadBalance()
    {
        try
        {
            var result = await Api.GetAgentBalanceAsync();
            if (result?.Success == true && result.Data != null)
                _balance = result.Data;
            else
                _error = result?.Message ?? "Failed to load balance.";
        }
        catch (Exception ex) { _error = $"Error: {ex.Message}"; }
    }

    private async Task LoadTransactions()
    {
        try
        {
            var result = await Api.GetAgentTransactionsAsync();
            if (result?.Success == true && result.Data != null)
                _transactions = result.Data;
        }
        catch { }
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "Completed" => Color.Success,
        "Pending" => Color.Warning,
        "Approved" => Color.Info,
        "Cancelled" or "Failed" => Color.Error,
        _ => Color.Default
    };
}
