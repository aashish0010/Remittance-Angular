@page "/agent/transactions"
@using Remittance.Web.Client.Models
@using Remittance.Web.Client.Services

<PageTitle>My Transactions - Agent Portal</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 700;">My Transactions</MudText>

@if (!string.IsNullOrEmpty(_error))
{
    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_error</MudAlert>
}

<MudPaper Elevation="4" Class="rounded-lg">
    <MudTable Items="_transactions" Hover="true" Striped="true" Dense="true" Loading="_loading"
              Filter="new Func<TransactionResult, bool>(FilterFunc)">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="Search transactions..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" />
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/agent/send"
                       StartIcon="@Icons.Material.Filled.Add">
                New Transaction
            </MudButton>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Reference</MudTh>
            <MudTh>Sender</MudTh>
            <MudTh>Receiver</MudTh>
            <MudTh>Send</MudTh>
            <MudTh>Receive</MudTh>
            <MudTh>My Commission</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Date</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><MudText Typo="Typo.body2" Style="font-family: monospace;">@context.ReferenceNumber</MudText></MudTd>
            <MudTd>@context.SenderName</MudTd>
            <MudTd>@context.ReceiverName</MudTd>
            <MudTd>@context.SendAmount.ToString("N2") @context.SendCurrency</MudTd>
            <MudTd>@context.ReceiveAmount.ToString("N2") @context.ReceiveCurrency</MudTd>
            <MudTd><MudText Color="Color.Success">@context.AgentCommission.ToString("C")</MudText></MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
            </MudTd>
            <MudTd>@context.CreatedAt.ToString("MMM dd, HH:mm")</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private List<TransactionResult> _transactions = new();
    private bool _loading = true;
    private string _search = string.Empty;
    private string _error = string.Empty;

    [Inject] private ApiService Api { get; set; } = null!;
    [Inject] private AuthStateService Auth { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        await Auth.LoadFromSessionAsync();
        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        _loading = true;
        try
        {
            var result = await Api.GetAgentTransactionsAsync();
            if (result?.Success == true && result.Data != null)
                _transactions = result.Data;
            else
            {
                _transactions = new();
                _error = result?.Message ?? "Failed to load transactions.";
            }
        }
        catch (Exception ex)
        {
            _transactions = new();
            _error = $"Could not connect to server: {ex.Message}";
        }
        finally { _loading = false; }
    }

    private bool FilterFunc(TransactionResult tx) =>
        string.IsNullOrWhiteSpace(_search) ||
        tx.ReferenceNumber.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
        tx.SenderName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
        tx.ReceiverName.Contains(_search, StringComparison.OrdinalIgnoreCase);

    private static Color GetStatusColor(string status) => status switch
    {
        "Completed" => Color.Success,
        "Pending" => Color.Warning,
        "Approved" => Color.Info,
        "Cancelled" or "Failed" => Color.Error,
        _ => Color.Default
    };
}
