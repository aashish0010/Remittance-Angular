@page "/agent/send"
@using Remittance.Web.Client.Models
@using Remittance.Web.Client.Services

<PageTitle>Send Money - Agent Portal</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 700;">Send Money</MudText>

@if (!string.IsNullOrEmpty(_error))
{
    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true" ShowCloseIcon="true"
              CloseIconClicked="@(() => _error = string.Empty)">@_error</MudAlert>
}

<MudGrid>
    <MudItem xs="12" md="8">
        <MudPaper Elevation="4" Class="pa-6 rounded-lg">
            <MudStepper @bind-ActiveIndex="_step">
                <MudStep Title="Sender Details">
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_model.SenderName" Label="Sender Full Name"
                                          Variant="Variant.Outlined" Required="true"
                                          Error="@(!string.IsNullOrEmpty(_validationErrors.GetValueOrDefault("SenderName")))"
                                          ErrorText="@_validationErrors.GetValueOrDefault("SenderName")" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_model.SenderPhone" Label="Sender Phone"
                                          Variant="Variant.Outlined" Required="true"
                                          Error="@(!string.IsNullOrEmpty(_validationErrors.GetValueOrDefault("SenderPhone")))"
                                          ErrorText="@_validationErrors.GetValueOrDefault("SenderPhone")" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_model.SenderEmail" Label="Sender Email"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="string" @bind-Value="_model.SenderCountry" Label="Sender Country"
                                       Variant="Variant.Outlined" Required="true">
                                @foreach (var c in _senderCountries) { <MudSelectItem Value="@c">@c</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="string" @bind-Value="_model.SenderIdType" Label="ID Type"
                                       Variant="Variant.Outlined">
                                <MudSelectItem Value="@("Passport")">Passport</MudSelectItem>
                                <MudSelectItem Value="@("DrivingLicense")">Driving License</MudSelectItem>
                                <MudSelectItem Value="@("NationalID")">National ID</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_model.SenderIdNumber" Label="ID Number"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                    </MudGrid>
                </MudStep>

                <MudStep Title="Receiver Details">
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_model.ReceiverName" Label="Receiver Full Name"
                                          Variant="Variant.Outlined" Required="true"
                                          Error="@(!string.IsNullOrEmpty(_validationErrors.GetValueOrDefault("ReceiverName")))"
                                          ErrorText="@_validationErrors.GetValueOrDefault("ReceiverName")" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_model.ReceiverPhone" Label="Receiver Phone"
                                          Variant="Variant.Outlined" Required="true"
                                          Error="@(!string.IsNullOrEmpty(_validationErrors.GetValueOrDefault("ReceiverPhone")))"
                                          ErrorText="@_validationErrors.GetValueOrDefault("ReceiverPhone")" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="string" @bind-Value="_model.ReceiverCountry" Label="Receiver Country"
                                       Variant="Variant.Outlined" Required="true">
                                @foreach (var c in _senderCountries) { <MudSelectItem Value="@c">@c</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_model.ReceiverEmail" Label="Receiver Email"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_model.ReceiverBankName" Label="Bank Name (Optional)"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_model.ReceiverAccountNumber" Label="Account Number (Optional)"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                    </MudGrid>
                </MudStep>

                <MudStep Title="Amount & Payment">
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudNumericField T="decimal" Value="_model.SendAmount" Label="Send Amount"
                                             Variant="Variant.Outlined" Adornment="Adornment.Start"
                                             AdornmentText="$" Format="N2"
                                             Immediate="true" ValueChanged="OnAmountChanged"
                                             Error="@(!string.IsNullOrEmpty(_validationErrors.GetValueOrDefault("SendAmount")))"
                                             ErrorText="@_validationErrors.GetValueOrDefault("SendAmount")" />
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudSelect T="string" Value="_model.SendCurrency" Label="Send Currency"
                                       Variant="Variant.Outlined" ValueChanged="OnSendCurrencyChanged">
                                @foreach (var c in _currencies) { <MudSelectItem Value="@c">@c</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudSelect T="string" Value="_model.ReceiveCurrency" Label="Receive Currency"
                                       Variant="Variant.Outlined" ValueChanged="OnReceiveCurrencyChanged">
                                @foreach (var c in _currencies) { <MudSelectItem Value="@c">@c</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_model.Purpose" Label="Purpose of Transfer"
                                          Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="int" @bind-Value="_model.PayoutMethod" Label="Payout Method"
                                       Variant="Variant.Outlined">
                                <MudSelectItem Value="0">Cash Pickup</MudSelectItem>
                                <MudSelectItem Value="1">Bank Transfer</MudSelectItem>
                                <MudSelectItem Value="4">Mobile Wallet</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </MudStep>
            </MudStepper>

            <div class="d-flex justify-end mt-4 gap-2">
                @if (_step > 0)
                {
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => _step--)">Back</MudButton>
                }
                @if (_step < 2)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowForward" OnClick="NextStep">Next</MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Send"
                               OnClick="SubmitTransaction" Disabled="_submitting">
                        @if (_submitting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Submit Transaction
                    </MudButton>
                }
            </div>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Elevation="4" Class="pa-4 rounded-lg" Style="position: sticky; top: 80px;">
            <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 600;">
                <MudIcon Icon="@Icons.Material.Filled.Calculate" Class="mr-1" /> Live Calculation
            </MudText>

            <div class="mb-3">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Send Amount</MudText>
                <MudText Typo="Typo.h5" Style="font-weight: 700;">@_model.SendAmount.ToString("N2") @_model.SendCurrency</MudText>
            </div>

            <MudDivider Class="my-2" />

            <div class="mb-3">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Exchange Rate</MudText>
                @if (_loadingRate)
                {
                    <MudProgressLinear Indeterminate="true" Size="Size.Small" />
                }
                else
                {
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">1 @_model.SendCurrency = @_exchangeRate.ToString("N4") @_model.ReceiveCurrency</MudText>
                }
            </div>

            <div class="mb-3">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Receive Amount</MudText>
                <MudText Typo="Typo.h4" Style="font-weight: 700;" Color="Color.Success">
                    @_receiveAmount.ToString("N2") @_model.ReceiveCurrency
                </MudText>
            </div>

            <MudDivider Class="my-2" />

            <div class="mb-2">
                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.body2">Commission:</MudText>
                    <MudText Typo="Typo.body2" Style="font-weight: 600;">@_commission.ToString("C")</MudText>
                </div>
                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.body2">Your Earning:</MudText>
                    <MudText Typo="Typo.body2" Style="font-weight: 600;" Color="Color.Success">@_agentComm.ToString("C")</MudText>
                </div>
            </div>

            <MudDivider Class="my-2" />

            <div class="d-flex justify-space-between">
                <MudText Typo="Typo.body1" Style="font-weight: 700;">Total Payable:</MudText>
                <MudText Typo="Typo.body1" Style="font-weight: 700;">@((_model.SendAmount + _commission).ToString("C"))</MudText>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private SendTransactionModel _model = new() { SendCurrency = "USD", ReceiveCurrency = "NPR", SenderCountry = "USA", ReceiverCountry = "Nepal" };
    private int _step;
    private bool _submitting;
    private bool _loadingRate;
    private decimal _exchangeRate;
    private decimal _receiveAmount;
    private decimal _commission;
    private decimal _agentComm;
    private string _error = string.Empty;
    private Dictionary<string, string> _validationErrors = new();

    private List<string> _senderCountries = new();
    private List<string> _receiverCountries = new();
    private List<string> _currencies = new();

    [Inject] private ISnackbar Snackbar { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;
    [Inject] private ApiService Api { get; set; } = null!;
    [Inject] private AuthStateService Auth { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        await Auth.LoadFromSessionAsync();
        await Task.WhenAll(LoadReferenceData(), FetchRate());
    }

    private async Task LoadReferenceData()
    {
        try
        {
            var cr = await Api.GetCountriesAsync();
            var cu = await Api.GetCurrenciesAsync();
            if (cr?.Success == true && cr.Data != null)
            {
                var all = cr.Data.Select(c => c.Name).ToList();
                _senderCountries = all;
                _receiverCountries = all;
            }
            if (cu?.Success == true && cu.Data != null)
                _currencies = cu.Data;
        }
        catch { }
    }

    private Task<IEnumerable<string>> SearchCountries(string value, CancellationToken token)
        => Task.FromResult(string.IsNullOrEmpty(value)
            ? _senderCountries.AsEnumerable()
            : _senderCountries.Where(c => c.Contains(value, StringComparison.OrdinalIgnoreCase)));

    private Task<IEnumerable<string>> SearchCurrencies(string value, CancellationToken token)
        => Task.FromResult(string.IsNullOrEmpty(value)
            ? _currencies.AsEnumerable()
            : _currencies.Where(c => c.Contains(value, StringComparison.OrdinalIgnoreCase)));

    private void NextStep()
    {
        _validationErrors.Clear();

        if (_step == 0)
        {
            if (string.IsNullOrWhiteSpace(_model.SenderName))
                _validationErrors["SenderName"] = "Sender name is required.";
            if (string.IsNullOrWhiteSpace(_model.SenderPhone))
                _validationErrors["SenderPhone"] = "Sender phone is required.";
            if (string.IsNullOrWhiteSpace(_model.SenderCountry))
                _validationErrors["SenderCountry"] = "Sender country is required.";
            if (_validationErrors.Count > 0) return;
        }
        else if (_step == 1)
        {
            if (string.IsNullOrWhiteSpace(_model.ReceiverName))
                _validationErrors["ReceiverName"] = "Receiver name is required.";
            if (string.IsNullOrWhiteSpace(_model.ReceiverPhone))
                _validationErrors["ReceiverPhone"] = "Receiver phone is required.";
            if (string.IsNullOrWhiteSpace(_model.ReceiverCountry))
                _validationErrors["ReceiverCountry"] = "Receiver country is required.";
            if (_validationErrors.Count > 0) return;
        }

        _step++;
    }

    private void OnAmountChanged(decimal amount)
    {
        _model.SendAmount = amount;
        RecalculateAmounts();
    }

    private async void OnSendCurrencyChanged(string val)
    {
        _model.SendCurrency = val;
        await FetchRate();
    }

    private async void OnReceiveCurrencyChanged(string val)
    {
        _model.ReceiveCurrency = val;
        await FetchRate();
    }

    private async Task FetchRate()
    {
        _loadingRate = true;
        StateHasChanged();
        try
        {
            var result = await Api.GetCurrentRateAsync(_model.SendCurrency, _model.ReceiveCurrency);
            if (result?.Success == true && result.Data != null)
                _exchangeRate = result.Data.Rate;
            else
                _exchangeRate = 0;
        }
        catch { _exchangeRate = 0; }
        _loadingRate = false;
        RecalculateAmounts();
        StateHasChanged();
    }

    private void RecalculateAmounts()
    {
        _receiveAmount = Math.Round(_model.SendAmount * _exchangeRate, 2);

        if (_model.SendAmount <= 500)
        {
            _commission = Math.Round(_model.SendAmount * 0.03m + 5, 2);
            _agentComm = Math.Round(_commission * 0.40m, 2);
        }
        else if (_model.SendAmount <= 2000)
        {
            _commission = Math.Round(_model.SendAmount * 0.025m + 3, 2);
            _agentComm = Math.Round(_commission * 0.45m, 2);
        }
        else
        {
            _commission = Math.Round(_model.SendAmount * 0.015m, 2);
            _agentComm = Math.Round(_commission * 0.50m, 2);
        }
    }

    private async Task SubmitTransaction()
    {
        _validationErrors.Clear();
        _error = string.Empty;

        if (_model.SendAmount <= 0)
        {
            _validationErrors["SendAmount"] = "Amount must be greater than zero.";
            return;
        }

        _submitting = true;
        try
        {
            var result = await Api.SendTransactionAsync(_model);
            if (result?.Success == true)
            {
                Snackbar.Add($"Transaction submitted! Ref: {result.Data?.ReferenceNumber}", Severity.Success);
                Navigation.NavigateTo("/agent/transactions");
            }
            else
            {
                _error = result?.Message ?? "Failed to submit transaction.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally { _submitting = false; }
    }
}
