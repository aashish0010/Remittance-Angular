@inherits LayoutComponentBase

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudMainContent Style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #1565C0 0%, #1976D2 50%, #42A5F5 100%);">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _isDarkMode = false;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1976D2",
            Secondary = "#7C4DFF",
            Background = "#F5F5F5",
            Surface = "#FFFFFF"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#42A5F5",
            Secondary = "#B388FF",
            Background = "#0D1117",
            Surface = "#1E1E1E"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography { FontFamily = new[] { "Inter", "Helvetica", "Arial", "sans-serif" } }
        }
    };
}
